    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Exception_ProfilingOverride</IRI>
        <Literal xml:lang="en">AI systems listed under Annex III are always considered high risk if they profile individuals, i.e. automated processing of personal data to assess various aspects of a person&apos;s life.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Exception_ProfilingOverride</IRI>
