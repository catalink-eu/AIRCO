    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#Condition_CodesOfPracticeParticipation</IRI>
        <Literal xml:lang="en">EU AI Act, Article 56(4)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Condition_CodesOfPracticeParticipation</IRI>
        <Literal xml:lang="en">AI Office may invite GPAI model providers, relevant national competent authorities to participate, while civil society, industry, academia, downstream providers, and independent experts may support the process.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Condition_CodesOfPracticeParticipation</IRI>
        <Literal xml:lang="en">Codes of Practice Participation Condition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#Condition_CodesOfPracticeScope</IRI>
        <Literal xml:lang="en">EU AI Act, Article 56(3)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Condition_CodesOfPracticeScope</IRI>
        <Literal xml:lang="en">Codes will cover but not necessarily be limited to: information in technical documentation for authorities and downstream providers, identification of type and nature of systemic risks and their sources, and modalities of risk management.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Condition_CodesOfPracticeScope</IRI>
        <Literal xml:lang="en">Codes of Practice Scope Condition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#Condition_EditorialResponsibility</IRI>
        <Literal xml:lang="en">EU AI Act, Article 50(4)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Condition_EditorialResponsibility</IRI>
        <Literal xml:lang="en">A natural or legal person must hold editorial responsibility for the publication.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Condition_EditorialResponsibility</IRI>
        <Literal xml:lang="en">Editorial Responsibility Condition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#Condition_HighImpactCapabilitiesOverride</IRI>
        <Literal xml:lang="en">EU AI Act, Article 51(1)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Condition_HighImpactCapabilitiesOverride</IRI>
        <Literal xml:lang="en">The Commission may decide, on its own or via qualified alert from the scientific panel of independent experts, that a model has high impact capabilities, rendering it systemic.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Condition_HighImpactCapabilitiesOverride</IRI>
        <Literal xml:lang="en">High Impact Capabilities Condition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#Condition_HumanAssessmentAugmentation</IRI>
        <Literal xml:lang="en">EU AI Act, Article 5(1)(e)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Condition_HumanAssessmentAugmentation</IRI>
        <Literal xml:lang="en">AI must augment rather than replace human assessments.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Condition_HumanAssessmentAugmentation</IRI>
        <Literal xml:lang="en">Human Assessment Augmentation Condition</Literal>
    </AnnotationAssertion>
