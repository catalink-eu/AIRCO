        <IRI>#GPAIObligation</IRI>
        <Literal xml:lang="en">EU AI Act, Article 53</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation</IRI>
        <Literal xml:lang="en">An obligation placed on providers of GPAI models.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation</IRI>
        <Literal xml:lang="en">GPAI Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_ComplianceDemonstration</IRI>
        <Literal xml:lang="en">EU AI Act, Article 56</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_ComplianceDemonstration</IRI>
        <Literal xml:lang="en">All GPAI model providers may demonstrate compliance by voluntarily adhering to a code of practice until European harmonised standards are published. Providers that don&apos;t adhere must demonstrate alternative adequate means of compliance for Commission approval.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_ComplianceDemonstration</IRI>
        <Literal xml:lang="en">GPAI Compliance Demonstration via Codes of Practice Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_CooperateWithHighRisk</IRI>
        <Literal xml:lang="en">EU AI Act, Article 53(4)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_CooperateWithHighRisk</IRI>
        <Literal xml:lang="en">GPAI system providers should cooperate with high-risk AI system providers to enable the latter&apos;s compliance.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_CooperateWithHighRisk</IRI>
        <Literal xml:lang="en">GPAI Cooperation with High-Risk AI Providers Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_CopyrightPolicy</IRI>
        <Literal xml:lang="en">EU AI Act, Article 53(1)(c)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_CopyrightPolicy</IRI>
        <Literal xml:lang="en">All providers of GPAI models must establish a policy to respect the Copyright Directive.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_CopyrightPolicy</IRI>
        <Literal xml:lang="en">GPAI Copyright Policy Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_Cybersecurity</IRI>
        <Literal xml:lang="en">EU AI Act, Article 55(1)(d)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_Cybersecurity</IRI>
        <Literal xml:lang="en">All providers of systemic GPAI models must ensure an adequate level of cybersecurity protection.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_Cybersecurity</IRI>
        <Literal xml:lang="en">GPAI Cybersecurity Protection Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_DownstreamProviderInfo</IRI>
        <Literal xml:lang="en">EU AI Act, Article 53(1)(b)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_DownstreamProviderInfo</IRI>
        <Literal xml:lang="en">All providers of GPAI models must draw up information and documentation to supply to downstream providers that intend to integrate the GPAI model into their own AI system, so the latter understands capabilities and limitations and is enabled to comply.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_DownstreamProviderInfo</IRI>
        <Literal xml:lang="en">GPAI Downstream Provider Information Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_ModelEvaluation</IRI>
        <Literal xml:lang="en">EU AI Act, Article 55(1)(a)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_ModelEvaluation</IRI>
        <Literal xml:lang="en">All providers of systemic GPAI models must perform model evaluations, including conducting and documenting adversarial testing to identify and mitigate systemic risk.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_ModelEvaluation</IRI>
        <Literal xml:lang="en">Model Evaluation for Systemic Risk Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_SeriousIncidentReporting</IRI>
        <Literal xml:lang="en">EU AI Act, Article 55(1)(c)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_SeriousIncidentReporting</IRI>
        <Literal xml:lang="en">All providers of systemic GPAI models must track, document, and report serious incidents and possible corrective measures to the AI Office and relevant national competent authorities without undue delay.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_SeriousIncidentReporting</IRI>
        <Literal xml:lang="en">Serious Incident Reporting Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_SystemicRiskMitigation</IRI>
        <Literal xml:lang="en">EU AI Act, Article 55(1)(b)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_SystemicRiskMitigation</IRI>
        <Literal xml:lang="en">All providers of systemic GPAI models must assess and mitigate possible systemic risks, including their sources.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_SystemicRiskMitigation</IRI>
        <Literal xml:lang="en">Systemic-Risk Assessment and Mitigation Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_SystemicRiskNotification</IRI>
        <Literal xml:lang="en">EU AI Act, Article 51(2)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_SystemicRiskNotification</IRI>
        <Literal xml:lang="en">All providers of systemic GPAI models must notify the Commission if their model meets the systemic risk criterion within 2 weeks.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_SystemicRiskNotification</IRI>
        <Literal xml:lang="en">Systemic-Risk Notification Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_TechnicalDocumentation</IRI>
        <Literal xml:lang="en">EU AI Act, Article 53(1)(a)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_TechnicalDocumentation</IRI>
        <Literal xml:lang="en">All providers of GPAI models must draw up technical documentation, including training and testing process and evaluation results.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_TechnicalDocumentation</IRI>
        <Literal xml:lang="en">GPAI Technical Documentation Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIObligation_TrainingSummary</IRI>
        <Literal xml:lang="en">EU AI Act, Article 53(1)(d)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIObligation_TrainingSummary</IRI>
        <Literal xml:lang="en">All providers of GPAI models must publish a sufficiently detailed summary about the content used for training the GPAI model.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIObligation_TrainingSummary</IRI>
        <Literal xml:lang="en">GPAI Training Summary Publication Obligation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIProvider</IRI>
        <Literal>EU AI Act, Article 53(1)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GPAIProvider</IRI>
        <Literal xml:lang="en">A provider of a GPAI model subject to all standard GPAI obligations: technical documentation, information and documentation to supply to downstream
providers, respect the Copyright Directive, sufficiently detailed summary about the content used for training .</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#GPAIProvider</IRI>
        <Literal xml:lang="en">GPAI Provider</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="terms:source"/>
        <IRI>#GPAIRiskCategory</IRI>
        <Literal xml:lang="en">EU AI Act, Chapter V, Articles 51-56</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
