        <IRI>#Exception_RemoteBiometricIdentification_UrgencyRegistration</IRI>
        <Literal xml:lang="en">EU AI Act, Article 5(3)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Exception_RemoteBiometricIdentification_UrgencyRegistration</IRI>
        <Literal xml:lang="en">In duly justified cases of urgency, deployment of remote biometric identification can commence without registration, provided that it is registered later without undue delay.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Exception_RemoteBiometricIdentification_UrgencyRegistration</IRI>
        <Literal xml:lang="en">Urgency Registration RBI Exception</Literal>
