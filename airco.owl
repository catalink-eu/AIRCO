    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Exception_RemoteBiometricIdentification_UrgencyAuthorisation</IRI>
        <Literal xml:lang="en">In duly justified cases of urgency, deployment of remote biometric identification can commence without authorisation, provided that authorisation is requested within 24 hours. If rejected, deployment must cease immediately, deleting all data, results, and outputs.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Exception_RemoteBiometricIdentification_UrgencyAuthorisation</IRI>
        <Literal xml:lang="en">Urgency Authorisation RBI Exception</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
