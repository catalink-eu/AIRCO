    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Exception_PublicCrimeReporting</IRI>
        <Literal xml:lang="en">Exception for when systems are available for the public to report a criminal offence.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Exception_PublicCrimeReporting</IRI>
