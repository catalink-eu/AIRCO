        <rdfs:comment xml:lang="en">Assessments of irregular migration or health risks.</rdfs:comment>
        <rdfs:label xml:lang="en">Irregular Migration or Health Risk Assessment High-Risk Use Case</rdfs:label>
    </owl:Class>
    


