            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(1)</terms:source>
        <rdfs:comment xml:lang="en">A provider of an AI system that directly interacts with people, subject to transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Interacting with People AI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#LawfullyAcquiredBiometricDataset -->

    <owl:Class rdf:about="https://w3id.org/airco#LawfullyAcquiredBiometricDataset">
