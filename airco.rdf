        <terms:source xml:lang="en">EU AI Act, Annex III, 6(e)</terms:source>
        <rdfs:comment xml:lang="en">Profiling during criminal detections, investigations, or prosecutions.</rdfs:comment>
        <rdfs:label xml:lang="en">Profiling During Criminal Detection, Investigation, or Prosecution High-Risk Use Case</rdfs:label>
    </owl:Class>
    


