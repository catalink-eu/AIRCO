    <!-- https://w3id.org/airco#Directive2016_680 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/airco#Directive2016_680">
        <rdf:type rdf:resource="https://w3id.org/airo#Regulation"/>
        <rdfs:comment xml:lang="en">Law Enforcement Directive.</rdfs:comment>
        <rdfs:label xml:lang="en">Directive (EU) 2016/680</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/airco#EUAIAct -->

    <owl:NamedIndividual rdf:about="https://w3id.org/airco#EUAIAct">
        <rdf:type rdf:resource="https://w3id.org/airo#Regulation"/>
        <rdfs:comment xml:lang="en">The EU Artificial Intelligence Act.</rdfs:comment>
        <rdfs:label xml:lang="en">EU AI Act</rdfs:label>
    </owl:NamedIndividual>
    


