        <rdfs:comment xml:lang="en">A biometric dataset that has been lawfully acquired.</rdfs:comment>
        <rdfs:label xml:lang="en">Lawfully Acquired Biometric Dataset</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ManipulativePurpose -->

    <owl:Class rdf:about="https://w3id.org/airco#ManipulativePurpose">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Purpose"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToTechnique"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ManipulativeTechnique"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Purpose of manipulating human behaviour through AI techniques.</rdfs:comment>
        <rdfs:label xml:lang="en">Manipulative Purpose</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ManipulativeTechnique -->

    <owl:Class rdf:about="https://w3id.org/airco#ManipulativeTechnique">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Technique"/>
        <rdfs:comment xml:lang="en">Technique that manipulates human behaviour.</rdfs:comment>
        <rdfs:label xml:lang="en">Manipulative Technique</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#MarkingRequirement -->

    <owl:Class rdf:about="https://w3id.org/airco#MarkingRequirement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A requirement to mark AI-generated content in machine-readable format.</rdfs:comment>
        <rdfs:label xml:lang="en">Marking Requirement</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#MissingPerson -->

    <owl:Class rdf:about="https://w3id.org/airco#MissingPerson">
