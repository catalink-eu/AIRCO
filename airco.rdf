    <!-- https://w3id.org/airco#IndependentAdministrativeAuthority -->

    <owl:Class rdf:about="https://w3id.org/airco#IndependentAdministrativeAuthority">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#AuthorisationBody"/>
        <rdfs:comment xml:lang="en">An independent administrative authority that can authorise real-time RemoteBiometricIdentification.</rdfs:comment>
        <rdfs:label xml:lang="en">Independent Administrative Authority</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#InteractingWithPeopleAIProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#InteractingWithPeopleAIProvider">
