                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ProhibitedUseCase_RealTimeRemoteBiometricIdentification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers ProhibitedUseCase_RealTimeRemoteBiometricIdentification.</rdfs:comment>
        <rdfs:label xml:lang="en">Real-Time Remote Biometric Identification System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_RecruitmentSelection -->

    <owl:Class rdf:about="https://w3id.org/airco#System_RecruitmentSelection">
        <owl:equivalentClass>
