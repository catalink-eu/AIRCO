                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ProhibitedUseCase_SocialScoring"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers ProhibitedUseCase_SocialScoring.</rdfs:comment>
        <rdfs:label xml:lang="en">Social Scoring System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_StandardGPAI -->

    <owl:Class rdf:about="https://w3id.org/airco#System_StandardGPAI">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasModel"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airo#GPAIModel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#StandardGPAIModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype for systems based on a GPAI without a free and open licence.</rdfs:comment>
        <rdfs:label xml:lang="en">Standard GPAI System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_SubliminalManipulativeDeceptive -->

    <owl:Class rdf:about="https://w3id.org/airco#System_SubliminalManipulativeDeceptive">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasPurpose"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ManipulativePurpose"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#usesTechnique"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/airco#ManipulativeTechnique"/>
                                    <rdf:Description rdf:about="https://w3id.org/vair#DeceptiveTechnique"/>
                                    <rdf:Description rdf:about="https://w3id.org/vair#SubliminalTechnique"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ProhibitedUseCase_SubliminalManipulativeDeceptive"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers ProhibitedUseCase_SubliminalManipulativeDeceptive.</rdfs:comment>
        <rdfs:label xml:lang="en">Subliminal/Manipulative/Deceptive AI System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_SyntheticContentGeneration -->

    <owl:Class rdf:about="https://w3id.org/airco#System_SyntheticContentGeneration">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasPurpose"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/vair#ContentGeneration"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase_SyntheticContentGeneration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers TransparencyRiskUseCase_SyntheticContentGeneration.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Content Generation System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_SystemicRiskGPAI -->

    <owl:Class rdf:about="https://w3id.org/airco#System_SystemicRiskGPAI">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airco#hasTrainingCharacteristic"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighComputeTraining"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasModel"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airo#GPAIModel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SystemicRiskGPAIModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype for systems based on a GPAI model that present systemic risks.</rdfs:comment>
        <rdfs:label xml:lang="en">Systemic Risk GPAI System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SystemicRiskGPAIModel -->

    <owl:Class rdf:about="https://w3id.org/airco#SystemicRiskGPAIModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#GPAIModel"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_HighImpactCapabilitiesOverride"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskSource"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighImpactCapability"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airco#hasTrainingCharacteristic"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighComputeTraining"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#hasStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SystemicRiskGPAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 51</terms:source>
        <rdfs:comment xml:lang="en">A GPAI model that presents systemic risks. GPAI models present systemic risks when they have high impact capabilities based on technical tools and methodologies, when the cumulative amount of compute used for training is greater than 10^25 FLOPs, or when the Commission determines high impact capabilities.</rdfs:comment>
        <rdfs:label xml:lang="en">Systemic-Risk GPAI Model</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SystemicRiskGPAIProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#SystemicRiskGPAIProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIProvider"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_CopyrightPolicy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_Cybersecurity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_DownstreamProviderInfo"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_ModelEvaluation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_SeriousIncidentReporting"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_SystemicRiskMitigation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_SystemicRiskNotification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_TrainingSummary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 51</terms:source>
        <rdfs:comment xml:lang="en">A provider of a GPAI model that presents systemic risks. Subject to additional obligations beyond standard GPAI obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Systemic-Risk GPAI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SystemicRiskObligation -->

    <owl:Class rdf:about="https://w3id.org/airco#SystemicRiskObligation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SystemicRiskGPAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#isObligationOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SystemicRiskGPAIModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 55</terms:source>
        <rdfs:comment xml:lang="en">Additional obligations for GPAI models with systemic risk, beyond the standard GPAI obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Systemic-Risk Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TradeUnionMembership -->

    <owl:Class rdf:about="https://w3id.org/airco#TradeUnionMembership">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Trade Union Membership</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TraffickingVictim -->

    <owl:Class rdf:about="https://w3id.org/airco#TraffickingVictim">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Victim"/>
        <rdfs:comment xml:lang="en">A person who has been human trafficked or sexually exploited, and is the subject of a search using real-time remote biometric identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Trafficking Victim</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TrainingSummary -->

    <owl:Class rdf:about="https://w3id.org/airco#TrainingSummary">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Documentation"/>
        <rdfs:comment xml:lang="en">A sufficiently detailed summary about the content used for training a GPAI model.</rdfs:comment>
        <rdfs:label xml:lang="en">Training Summary</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#TransparencyMeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50</terms:source>
        <rdfs:comment xml:lang="en">A transparency obligation under Article 50 of the EU AI Act.</rdfs:comment>
        <rdfs:label xml:lang="en">Transparency Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_BiometricCategorisationDisclosure -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_BiometricCategorisationDisclosure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#DisclosureRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#BiometricCategorisationAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#NaturalPerson"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_CriminalLawEnforcement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#Directive2016_680"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#GDPR"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#Regulation2018_1725"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(3)</terms:source>
        <rdfs:comment xml:lang="en">Deployers of biometric categorisation systems must inform affected individuals and comply with applicable EU data protection laws.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Categorisation Disclosure Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_CodesOfPractice -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_CodesOfPractice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#AIOffice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#governsObligation"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_DeepFakeDisclosure"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_SyntheticContentGenerationMarking"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(7)</terms:source>
        <rdfs:comment xml:lang="en">The AI Office shall encourage and facilitate drawing up of codes of practice at Union level to facilitate detection and labelling of artificially generated or manipulated content.</rdfs:comment>
        <rdfs:label xml:lang="en">Codes of Practice for Content Labelling Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_DeepFakeDisclosure -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_DeepFakeDisclosure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#DisclosureRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#DeepFakeAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_ArtisticFictionalWork"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_CriminalLawEnforcement"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">Deployers of AI systems generating or manipulating image, audio, or video deep fakes must disclose that content has been artificially generated or manipulated.</rdfs:comment>
        <rdfs:label xml:lang="en">Deep Fake Disclosure Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_EmotionRecognitionDisclosure -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_EmotionRecognitionDisclosure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#DisclosureRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#EmotionRecognitionAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#NaturalPerson"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_CriminalLawEnforcement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#Directive2016_680"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#GDPR"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#Regulation2018_1725"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(3)</terms:source>
        <rdfs:comment xml:lang="en">Deployers of emotion recognition systems must inform affected individuals and comply with applicable EU data protection laws.</rdfs:comment>
        <rdfs:label xml:lang="en">Emotion Recognition Disclosure Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_InteractingWithPeopleNotification -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_InteractingWithPeopleNotification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#NotificationRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#InteractingWithPeopleAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#NaturalPerson"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_NotObviousAI"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_CriminalLawEnforcement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(1)</terms:source>
        <rdfs:comment xml:lang="en">Providers must ensure that individuals are informed when they are interacting with an AI system, unless this is obvious in the given context.</rdfs:comment>
        <rdfs:label xml:lang="en">AI Interacting with People Notification Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_PublicInterestTextGenerationDisclosure -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_PublicInterestTextGenerationDisclosure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#DisclosureRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PublicInterestTextGenerationAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_CriminalLawEnforcement"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_HumanEditorialReview"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">Deployers of AI systems generating or manipulating text published with the purpose of informing the public on matters of public interest must disclose that the text has been artificially generated or manipulated.</rdfs:comment>
        <rdfs:label xml:lang="en">Public Interest AI Text Generation Disclosure Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_SyntheticContentGenerationMarking -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_SyntheticContentGenerationMarking">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#MarkingRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SyntheticContentGenerationAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_TechnicalFeasibility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_AssistiveEditing"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_CriminalLawEnforcement"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_NoSubstantialAlteration"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(2)</terms:source>
        <rdfs:comment xml:lang="en">Providers of AI systems generating synthetic audio, image, video, or text content must ensure outputs are marked in machine-readable format and detectable as artificially generated or manipulated.</rdfs:comment>
        <rdfs:label xml:lang="en">Machine-Readable Synthetic Content Marking Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyObligation_TimelinessAccessibility -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyObligation_TimelinessAccessibility">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#governsObligation"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_DeepFakeDisclosure"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_EmotionRecognitionDisclosure"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_InteractingWithPeopleNotification"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_PublicInterestTextGenerationDisclosure"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyObligation_SyntheticContentGenerationMarking"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(5)</terms:source>
        <rdfs:comment xml:lang="en">Information under Article 50(1)-(4) must be provided in a clear and distinguishable manner at the latest at the time of the first interaction or exposure, and must conform to applicable accessibility requirements.</rdfs:comment>
        <rdfs:label xml:lang="en">Timeliness and Accessibility of Transparency Information Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskAIDeployer -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskAIDeployer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AIDeployer"/>
        <rdfs:comment xml:lang="en">Deployer of an AI System with transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Transparency-Risk AI Deployer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskAIProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskAIProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AIProvider"/>
        <rdfs:comment xml:lang="en">Provider of an AI System with transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Transparency-Risk AI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskCategory -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#RiskCategory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggeredByRegulation"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#DisclosureRequirement"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#MarkingRequirement"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#NotificationRequirement"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Chapter IV, Article 50</terms:source>
        <rdfs:comment xml:lang="en">The Transparency-Risk category in the AI Act relating to transparency obligations in AI systems.</rdfs:comment>
        <rdfs:label xml:lang="en">Transparency-Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#UseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyRiskAIDeployer"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TransparencyRiskAIProvider"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Transparency-Risk AI practice requiring transparency measures.</rdfs:comment>
        <rdfs:label xml:lang="en">Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase_BiometricCategorisation -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase_BiometricCategorisation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#BiometricCategorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#BiometricCategorisationAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(3)</terms:source>
        <rdfs:comment xml:lang="en">Biometric-categorisation systems.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Categorisation Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase_DeepFakeGeneration -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase_DeepFakeGeneration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#DeepFakeGeneration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#DeepFakeAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">Generating or manipulating image, audio, or video deep fakes.</rdfs:comment>
        <rdfs:label xml:lang="en">Deep Fake Generation Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase_EmotionRecognition -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase_EmotionRecognition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#EmotionRecognition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#EmotionRecognitionAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(3)</terms:source>
        <rdfs:comment xml:lang="en">Emotion-recognition systems.</rdfs:comment>
        <rdfs:label xml:lang="en">Emotion Recognition Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase_InteractingWithPeople -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase_InteractingWithPeople">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#InteractingWithPeopleAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#NaturalPerson"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasSubjectInvolvement"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#ActiveInvolvement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(1)</terms:source>
        <rdfs:comment xml:lang="en">AI directly interacting with people.</rdfs:comment>
        <rdfs:label xml:lang="en">AI Interacting with People Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase_PublicInterestTextGeneration -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase_PublicInterestTextGeneration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToContentType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SyntheticTextContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PublicInterestTextGeneration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PublicInterestTextGenerationAIDeployer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">Generating or manipulating text published with the purpose of informing the public on matters of public interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Public Interest Text AI Generation Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#TransparencyRiskUseCase_SyntheticContentGeneration -->

    <owl:Class rdf:about="https://w3id.org/airco#TransparencyRiskUseCase_SyntheticContentGeneration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#GeneratingTextContent"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#GeneratingAudioContent"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#GeneratingImageContent"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#GeneratingVideoContent"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SyntheticContentGenerationAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(2)</terms:source>
        <rdfs:comment xml:lang="en">Generating synthetic audio, image, video, or text content.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Content Generation Transparency-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#UrgentPatientTriage -->

    <owl:Class rdf:about="https://w3id.org/airco#UrgentPatientTriage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#EmergencyTriage"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Health"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#EmergencyHealthCareProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Urgent patient triage in emergency healthcare, classified as high risk under emergency call evaluation.</rdfs:comment>
        <rdfs:label xml:lang="en">Urgent Patient Triage</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#UseCase -->

    <owl:Class rdf:about="https://w3id.org/airco#UseCase">
        <rdfs:comment xml:lang="en">A specific use case of an AI system under the EU AI Act. Use cases are classified into risk categories based on applicable classification rules.</rdfs:comment>
        <rdfs:label xml:lang="en">Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Victim -->

    <owl:Class rdf:about="https://w3id.org/airco#Victim">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISubject"/>
        <rdfs:comment xml:lang="en">A person who has suffered harm from, or is the target of, a criminal offence or other wrongful act.</rdfs:comment>
        <rdfs:label xml:lang="en">Victim</rdfs:label>
    </owl:Class>
    


