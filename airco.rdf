<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/airco#"
     xml:base="https://w3id.org/airco"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:airo="https://w3id.org/airo#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vair="https://w3id.org/vair#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/airco">
        <owl:imports rdf:resource="https://w3id.org/airo"/>
        <owl:imports rdf:resource="https://w3id.org/vair"/>
        <terms:description xml:lang="en">Encodes EU AI Act risk categories, obligations, exceptions, and transparency requirements. Aligned with AIRO and VAIR ontologies.</terms:description>
        <terms:source xml:lang="en">EU AI Act</terms:source>
        <terms:title xml:lang="en">AI Risk Compliance Ontology</terms:title>
        <rdfs:label xml:lang="en">AI Risk Compliance Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/airco#affectsArea -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#affectsArea">
        <rdfs:range rdf:resource="https://w3id.org/airo#AreaOfImpact"/>
        <rdfs:comment xml:lang="en">Links an entity to the impact area it affects.</rdfs:comment>
        <rdfs:label xml:lang="en">affects area</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToCapability -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToCapability">
        <rdfs:range rdf:resource="https://w3id.org/airo#AICapability"/>
        <rdfs:comment xml:lang="en">Links an entity to the AI capability it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to capability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToContentType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToContentType">
        <rdfs:range rdf:resource="https://w3id.org/vair#Content"/>
        <rdfs:comment xml:lang="en">Links an entity to the content type it covers.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to content type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToDomain -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToDomain">
        <rdfs:range rdf:resource="https://w3id.org/airo#Domain"/>
        <rdfs:comment xml:lang="en">Links an entity to the domain in which it applies.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to domain</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToInput -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToInput">
        <rdfs:range rdf:resource="https://w3id.org/airo#Input"/>
        <rdfs:comment xml:lang="en">Links an entity to the type of input data it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to input</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToLocality -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToLocality">
        <rdfs:range rdf:resource="https://w3id.org/airo#LocalityOfUse"/>
        <rdfs:comment xml:lang="en">Links an entity to the locality of use it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to locality</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToPurpose -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToPurpose">
        <rdfs:range rdf:resource="https://w3id.org/airo#Purpose"/>
        <rdfs:comment xml:lang="en">Links an entity to the purpose it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to purpose</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToStakeholder -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToStakeholder">
        <rdfs:range rdf:resource="https://w3id.org/airo#Stakeholder"/>
        <rdfs:comment xml:lang="en">Links an entity to the stakeholder role responsible.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to stakeholder</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToSubject -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToSubject">
        <rdfs:range rdf:resource="https://w3id.org/airo#AISubject"/>
        <rdfs:comment xml:lang="en">Links an entity to the type of AI subject it affects.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to subject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToSystem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToSystem">
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AIModel"/>
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links an entity to the AI system it applies to.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to system</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#appliesToTechnique -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#appliesToTechnique">
        <rdfs:range rdf:resource="https://w3id.org/airo#Technique"/>
        <rdfs:comment xml:lang="en">Links an entity to the AI technique it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to technique</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#causesConsequence -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#causesConsequence">
        <rdfs:range rdf:resource="https://w3id.org/airo#Consequence"/>
        <rdfs:comment xml:lang="en">Links an entity to the consequence it causes.</rdfs:comment>
        <rdfs:label xml:lang="en">causes consequence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#causesImpact -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#causesImpact">
        <rdfs:range rdf:resource="https://w3id.org/airo#Impact"/>
        <rdfs:comment xml:lang="en">Links an entity to the impact it causes.</rdfs:comment>
        <rdfs:label xml:lang="en">causes impact</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#exploitsVulnerabilityType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#exploitsVulnerabilityType">
        <rdfs:range rdf:resource="https://w3id.org/airo#Vulnerability"/>
        <rdfs:comment xml:lang="en">Links an entity to the specific vulnerability type exploited.</rdfs:comment>
        <rdfs:label xml:lang="en">exploits vulnerability type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#governsObligation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#governsObligation">
        <rdfs:domain rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:range rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:comment xml:lang="en">Links one obligation to another obligation whose implementation it governs or qualifies.</rdfs:comment>
        <rdfs:label xml:lang="en">governs obligation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasCondition -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasCondition">
        <rdfs:range rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:comment xml:lang="en">Links an entity to a condition under which it applies.</rdfs:comment>
        <rdfs:label xml:lang="en">has condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasDataSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasDataSource">
        <rdfs:range rdf:resource="https://w3id.org/dpv#Data"/>
        <rdfs:comment xml:lang="en">Links an entity to the data source type involved.</rdfs:comment>
        <rdfs:label xml:lang="en">has data source</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasException -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasException">
        <rdfs:range rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:comment xml:lang="en">Links an entity to a exception under which it won&apos;t apply.</rdfs:comment>
        <rdfs:label xml:lang="en">has exception</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasObligation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasObligation">
        <rdfs:range rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:comment xml:lang="en">Links an entity to an obligation it must fulfil.</rdfs:comment>
        <rdfs:label xml:lang="en">has obligation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasRiskCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasRiskCategory">
        <rdfs:range rdf:resource="https://w3id.org/airco#RiskCategory"/>
        <rdfs:comment xml:lang="en">Links an entity to a risk category.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasRiskSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasRiskSource">
        <rdfs:range rdf:resource="https://w3id.org/airo#RiskSource"/>
        <rdfs:comment xml:lang="en">Links an entity to a risk source.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk source</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasSubjectInvolvement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasSubjectInvolvement">
        <rdfs:range rdf:resource="https://w3id.org/airo#HumanInvolvement"/>
        <rdfs:comment xml:lang="en">Links an entity to the involvement level of its subject.</rdfs:comment>
        <rdfs:label xml:lang="en">has subject involvement type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#hasTrainingCharacteristic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#hasTrainingCharacteristic">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AIModel"/>
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">Links an AI system to a characteristic of its training process.</rdfs:comment>
        <rdfs:label xml:lang="en">has training characteristic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#includesCrimeType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#includesCrimeType">
        <rdfs:range rdf:resource="https://w3id.org/airco#SeriousCrime"/>
        <rdfs:comment xml:lang="en">Links an entity to a type of serious crime it encompasses.</rdfs:comment>
        <rdfs:label xml:lang="en">includes crime type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#infersSensitiveAttribute -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#infersSensitiveAttribute">
        <rdfs:range rdf:resource="https://w3id.org/airco#SensitiveAttribute"/>
        <rdfs:comment xml:lang="en">Links an entity to the sensitive attribute it infers.</rdfs:comment>
        <rdfs:label xml:lang="en">infers sensitive attribute</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#isExceptionTo -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#isExceptionTo">
        <rdfs:domain rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:comment xml:lang="en">Links an exception to the rule it modifies.</rdfs:comment>
        <rdfs:label xml:lang="en">is exception to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#isObligationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#isObligationOf">
        <rdfs:domain rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:comment xml:lang="en">Links an obligation to the entity it burdens.</rdfs:comment>
        <rdfs:label xml:lang="en">is obligation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#registersIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#registersIn">
        <rdfs:range rdf:resource="https://w3id.org/airco#Database"/>
        <rdfs:comment xml:lang="en">Links an entity to a database in which registration is required or specified.</rdfs:comment>
        <rdfs:label xml:lang="en">registers in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#requiresAuthorisation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#requiresAuthorisation">
        <rdfs:range rdf:resource="https://w3id.org/airco#AuthorisationBody"/>
        <rdfs:comment xml:lang="en">Links an entity to the authorisation body that must approve it.</rdfs:comment>
        <rdfs:label xml:lang="en">requires authorisation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#requiresDocumentation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#requiresDocumentation">
        <rdfs:range rdf:resource="https://w3id.org/airo#Documentation"/>
        <rdfs:comment xml:lang="en">Links an entity to the documentation it requires.</rdfs:comment>
        <rdfs:label xml:lang="en">requires documentation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#requiresRiskControl -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#requiresRiskControl">
        <rdfs:range rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">Links an entity to a risk control measure it mandates.</rdfs:comment>
        <rdfs:label xml:lang="en">requires risk control</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#triggeredByRegulation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#triggeredByRegulation">
        <rdfs:domain rdf:resource="https://w3id.org/airco#RiskCategory"/>
        <rdfs:comment xml:lang="en">Links an AI risk category to the regulation that triggers its risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">triggered by regulation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/airco#triggersRegulation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/airco#triggersRegulation">
        <rdfs:domain rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:comment xml:lang="en">Links an AI system archetype to the regulatory class (prohibition, use case, transparency obligation, or risk category) it triggers when a system matches its detection criteria.</rdfs:comment>
        <rdfs:label xml:lang="en">triggers regulation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/airco#hasComputeThreshold -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/airco#hasComputeThreshold">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Compute threshold value for classification.</rdfs:comment>
        <rdfs:label xml:lang="en">has compute threshold</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/airco#AIOffice -->

    <owl:Class rdf:about="https://w3id.org/airco#AIOffice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Stakeholder"/>
        <rdfs:comment xml:lang="en">The EU AI Office.</rdfs:comment>
        <rdfs:label xml:lang="en">AI Office</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#AbductionVictim -->

    <owl:Class rdf:about="https://w3id.org/airco#AbductionVictim">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Victim"/>
        <rdfs:comment xml:lang="en">A victim of abduction who is the subject of a search using real-time remote biometric identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Abduction Victim</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#AgeVulnerability -->

    <owl:Class rdf:about="https://w3id.org/airco#AgeVulnerability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Vulnerability"/>
        <rdfs:label xml:lang="en">Age Vulnerability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#AlternativeDisputeResolution -->

    <owl:Class rdf:about="https://w3id.org/airco#AlternativeDisputeResolution">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#SettlingDispute"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#AdministrationOfJustice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Use of AI in alternative dispute resolution, classified as high risk under the administration of justice.</rdfs:comment>
        <rdfs:label xml:lang="en">Alternative Dispute Resolution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ArmedRobbery -->

    <owl:Class rdf:about="https://w3id.org/airco#ArmedRobbery">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SeriousCrime"/>
        <rdfs:label xml:lang="en">Armed Robbery</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#AuthorisationBody -->

    <owl:Class rdf:about="https://w3id.org/airco#AuthorisationBody">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Stakeholder"/>
        <rdfs:comment xml:lang="en">A body that can authorise certain AI practices.</rdfs:comment>
        <rdfs:label xml:lang="en">Authorisation Body</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#BiometricCategorisationAIDeployer -->

    <owl:Class rdf:about="https://w3id.org/airco#BiometricCategorisationAIDeployer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskAIDeployer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyObligation_BiometricCategorisationDisclosure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(3)</terms:source>
        <rdfs:comment xml:lang="en">A deployer of a biometric-categorisation system, subject to transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Categorisation AI Deployer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#BiometricData -->

    <owl:Class rdf:about="https://w3id.org/airco#BiometricData">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Input"/>
        <rdfs:comment xml:lang="en">Biometric data used as input to an AI system.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Data</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#CCTVFootage -->

    <owl:Class rdf:about="https://w3id.org/airco#CCTVFootage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/dpv#SensitiveData"/>
        <rdfs:comment xml:lang="en">CCTV footage used as a data source.</rdfs:comment>
        <rdfs:label xml:lang="en">CCTV Footage</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition">
        <rdfs:comment xml:lang="en">A condition that must be satisfied for a rule or exception to apply.</rdfs:comment>
        <rdfs:label xml:lang="en">Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_CodesOfPracticeParticipation -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_CodesOfPracticeParticipation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#AIOffice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#DownstreamProvider"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#NationalCompetentAuthority"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#ScientificPanelOfExperts"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 56(4)</terms:source>
        <rdfs:comment xml:lang="en">AI Office may invite GPAI model providers, relevant national competent authorities to participate, while civil society, industry, academia, downstream providers, and independent experts may support the process.</rdfs:comment>
        <rdfs:label xml:lang="en">Codes of Practice Participation Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_CodesOfPracticeScope -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_CodesOfPracticeScope">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#TechnicalDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#followsCodeOfConduct"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airo#CodeOfConduct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 56(3)</terms:source>
        <rdfs:comment xml:lang="en">Codes will cover but not necessarily be limited to: information in technical documentation for authorities and downstream providers, identification of type and nature of systemic risks and their sources, and modalities of risk management.</rdfs:comment>
        <rdfs:label xml:lang="en">Codes of Practice Scope Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_EditorialResponsibility -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_EditorialResponsibility">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">A natural or legal person must hold editorial responsibility for the publication.</rdfs:comment>
        <rdfs:label xml:lang="en">Editorial Responsibility Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_HighImpactCapabilitiesOverride -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_HighImpactCapabilitiesOverride">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ScientificPanelOfExperts"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 51(1)</terms:source>
        <rdfs:comment xml:lang="en">The Commission may decide, on its own or via qualified alert from the scientific panel of independent experts, that a model has high impact capabilities, rendering it systemic.</rdfs:comment>
        <rdfs:label xml:lang="en">High Impact Capabilities Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_HumanAssessmentAugmentation -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_HumanAssessmentAugmentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(e)</terms:source>
        <rdfs:comment xml:lang="en">AI must augment rather than replace human assessments.</rdfs:comment>
        <rdfs:label xml:lang="en">Human Assessment Augmentation Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_LawfullyAcquiredDataset -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_LawfullyAcquiredDataset">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasDataSource"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#LawfullyAcquiredBiometricDataset"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(c)</terms:source>
        <rdfs:comment xml:lang="en">The biometric dataset must have been lawfully acquired.</rdfs:comment>
        <rdfs:label xml:lang="en">Lawfully Acquired Dataset Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_MeaningfulHumanReview -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_MeaningfulHumanReview">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">The AI-generated content must have undergone meaningful human editorial review.</rdfs:comment>
        <rdfs:label xml:lang="en">Meaningful Human Review Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_NonHamperingDisclosure -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_NonHamperingDisclosure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">Disclosure must not hamper the display or enjoyment of the work.</rdfs:comment>
        <rdfs:label xml:lang="en">Non-Hampering Disclosure Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_NotObviousAI -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_NotObviousAI">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasSubjectInvolvement"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#InformedInvolvement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(1)</terms:source>
        <rdfs:comment xml:lang="en">Applies unless it is obvious from the point of view of a reasonably well-informed, observant, and circumspect natural person.</rdfs:comment>
        <rdfs:label xml:lang="en">Not Obviously AI Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_NotReplacingHumanAssessment -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_NotReplacingHumanAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">The AI system must not be meant to replace or influence the previously completed human assessment without proper human review.</rdfs:comment>
        <rdfs:label xml:lang="en">Not Replacing Human Assessment Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_NotSystemic -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_NotSystemic">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSystem"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SystemicRiskGPAIModel"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(2)</terms:source>
        <rdfs:comment xml:lang="en">System must not present systemic risks.</rdfs:comment>
        <rdfs:label xml:lang="en">Not Systemic Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_ObjectiveVerifiableFacts -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_ObjectiveVerifiableFacts">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToInput"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ObjectiveVerifiableFact"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(e)</terms:source>
        <rdfs:comment xml:lang="en">Must be based on objective, verifiable facts directly linked to criminal activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Objective Verifiable Facts Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 5(2)</terms:source>
        <rdfs:comment xml:lang="en">Using AI-enabled real-time remote biometric identification must account for affected persons&apos; rights and freedoms.</rdfs:comment>
        <rdfs:label xml:lang="en">Account for Rights and Freedoms Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 5(2)</terms:source>
        <rdfs:comment xml:lang="en">Real-time remote biometric identification is only allowed when not using the tool would cause considerable harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Considerable Harm Without Tool Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#PreDeploymentCondition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#FundamentalRightsImpactAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(3)</terms:source>
        <rdfs:comment xml:lang="en">Police must complete a fundamental rights impact assessment before deployment of remote biometric identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Fundamental Rights Impact Assessment Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#PreDeploymentCondition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyAuthorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresAuthorisation"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#IndependentAdministrativeAuthority"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#JudicialAuthority"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(4)</terms:source>
        <rdfs:comment xml:lang="en">Must obtain authorisation from a judicial authority or independent administrative authority before deployment of remote biometric identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Obtain Authorisation Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#PreDeploymentCondition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyRegistration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#registersIn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#EUDatabase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(3)</terms:source>
        <rdfs:comment xml:lang="en">The system must be registered in the EU database before deployment of remote biometric identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Register in EU Database Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_SafetyComponentOrProduct -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_SafetyComponentOrProduct">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 6(1)</terms:source>
        <rdfs:comment xml:lang="en">The AI system must be used as a safety component or be a product covered by EU laws in Annex I.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Component or Product Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_SolelyBasedOnProfiling -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_SolelyBasedOnProfiling">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/vair#Profiling"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(e), Annex III, 6(d)</terms:source>
        <rdfs:comment xml:lang="en">The assessment must be solely based on profiling or personality traits, without other evidence.</rdfs:comment>
        <rdfs:label xml:lang="en">Solely Based on Profiling Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_TechnicalFeasibility -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_TechnicalFeasibility">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(2)</terms:source>
        <rdfs:comment xml:lang="en">Solutions must be effective, interoperable, robust, and reliable as far as technically feasible.</rdfs:comment>
        <rdfs:label xml:lang="en">Technical Feasibility Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Condition_ThirdPartyConformityAssessment -->

    <owl:Class rdf:about="https://w3id.org/airco#Condition_ThirdPartyConformityAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <terms:source xml:lang="en">EU AI Act, Article 6(1)</terms:source>
        <rdfs:comment xml:lang="en">Must be required to undergo a third-party conformity assessment under Annex I laws.</rdfs:comment>
        <rdfs:label xml:lang="en">Third-Party Conformity Assessment Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#CopyrightPolicy -->

    <owl:Class rdf:about="https://w3id.org/airco#CopyrightPolicy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Documentation"/>
        <rdfs:comment xml:lang="en">A policy established to respect the Copyright Directive.</rdfs:comment>
        <rdfs:label xml:lang="en">Copyright Policy</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#CybersecurityProtection -->

    <owl:Class rdf:about="https://w3id.org/airco#CybersecurityProtection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#SecurityMeasure"/>
        <rdfs:comment xml:lang="en">An adequate level of cybersecurity protection.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Protection</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DataGovernance -->

    <owl:Class rdf:about="https://w3id.org/airco#DataGovernance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">Data governance measures ensuring training, validation, and testing datasets are relevant, representative, free of errors, and complete.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Governance</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Database -->

    <owl:Class rdf:about="https://w3id.org/airco#Database">
        <rdfs:comment xml:lang="en">A structured repository for storing and retrieving data.</rdfs:comment>
        <rdfs:label xml:lang="en">Database</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DecisionPatternDetection -->

    <owl:Class rdf:about="https://w3id.org/airco#DecisionPatternDetection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AICapability"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PatternRecognition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The capability of an AI system to detect decision-making patterns or deviations from prior decision-making patterns, without replacing or influencing previously completed human assessments.</rdfs:comment>
        <rdfs:label xml:lang="en">Decision Pattern Detection Capability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DeepFakeAIDeployer -->

    <owl:Class rdf:about="https://w3id.org/airco#DeepFakeAIDeployer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskAIDeployer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyObligation_DeepFakeDisclosure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">A deployer of an AI System generating or manipulating image, audio, or video deep fakes, subject to transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Deep Fake AI Deployer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DeepFakeGeneration -->

    <owl:Class rdf:about="https://w3id.org/airco#DeepFakeGeneration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#ContentGeneration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToContentType"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#SyntheticAudioContent"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SyntheticImageContent"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SyntheticVideoContent"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Purpose of generating or manipulating image, audio, or video content constituting a deep fake.</rdfs:comment>
        <rdfs:label xml:lang="en">Deep Fake Generation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DisabilityVulnerability -->

    <owl:Class rdf:about="https://w3id.org/airco#DisabilityVulnerability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Vulnerability"/>
        <rdfs:label xml:lang="en">Disability Vulnerability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DisclosureRequirement -->

    <owl:Class rdf:about="https://w3id.org/airco#DisclosureRequirement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A requirement to disclose AI involvement to affected persons.</rdfs:comment>
        <rdfs:label xml:lang="en">Disclosure Requirement</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DownstreamProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#DownstreamProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AIProvider"/>
        <terms:source xml:lang="en">EU AI Act, Article 3(68)</terms:source>
        <rdfs:comment xml:lang="en">A provider of an AI system, including a general-purpose AI system, which integrates an AI model, regardless of whether the AI model is provided by themselves and vertically integrated or provided by another entity based on contractual relations.</rdfs:comment>
        <rdfs:label xml:lang="en">Downstream Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#DownstreamProviderDocumentation -->

    <owl:Class rdf:about="https://w3id.org/airco#DownstreamProviderDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Documentation"/>
        <rdfs:comment xml:lang="en">Information and documentation supplied to downstream providers to understand capabilities and limitations.</rdfs:comment>
        <rdfs:label xml:lang="en">Downstream Provider Documentation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#EUDatabase -->

    <owl:Class rdf:about="https://w3id.org/airco#EUDatabase">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#RegulatoryDatabase"/>
        <rdfs:comment xml:lang="en">The EU database in which high-risk AI systems and real-time remote biometric identification systems must be registered before deployment.</rdfs:comment>
        <rdfs:label xml:lang="en">EU Database</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#EmotionInferenceInEducation -->

    <owl:Class rdf:about="https://w3id.org/airco#EmotionInferenceInEducation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#DetectingEmotionalState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToLocality"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#EducationalSetting"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Student"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Purpose of inferring emotions specifically in educational institution contexts.</rdfs:comment>
        <rdfs:label xml:lang="en">Emotion Inference In Education</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#EmotionInferenceInWorkplace -->

    <owl:Class rdf:about="https://w3id.org/airco#EmotionInferenceInWorkplace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#DetectingEmotionalState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToLocality"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Workplace"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Employee"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Purpose of inferring emotions specifically in workplace contexts.</rdfs:comment>
        <rdfs:label xml:lang="en">Emotion Inference In Workplace</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#EmotionRecognitionAIDeployer -->

    <owl:Class rdf:about="https://w3id.org/airco#EmotionRecognitionAIDeployer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskAIDeployer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyObligation_EmotionRecognitionDisclosure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(3)</terms:source>
        <rdfs:comment xml:lang="en">A deployer of an emotion-recognition system, subject to transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Emotion Recognition AI Deployer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#EnvironmentalCrime -->

    <owl:Class rdf:about="https://w3id.org/airco#EnvironmentalCrime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SeriousCrime"/>
        <rdfs:label xml:lang="en">Environmental Crime</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception">
        <rdfs:comment xml:lang="en">An exception to a rule under the AI Act.</rdfs:comment>
        <rdfs:label xml:lang="en">Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_ArtisticFictionalWork -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_ArtisticFictionalWork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_NonHamperingDisclosure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">For artistic, creative, satirical, fictional, or analogous works, transparency is limited to disclosure that does not hamper the display or enjoyment of the work.</rdfs:comment>
        <rdfs:label xml:lang="en">Artistic, Fictional, or Satirical Work Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_AssistiveEditing -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_AssistiveEditing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(2)</terms:source>
        <rdfs:comment xml:lang="en">Exception for AI systems that perform an assistive function for standard editing.</rdfs:comment>
        <rdfs:label xml:lang="en">Assistive Editing Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_AugmentingHumanAssessment -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_AugmentingHumanAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_HumanAssessmentAugmentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_ObjectiveVerifiableFacts"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(e)</terms:source>
        <rdfs:comment xml:lang="en">Exception when used to augment human assessments based on objective, verifiable facts directly linked to criminal activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Augmenting Human Assessments Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_BiometricVerification -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_BiometricVerification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#BiometricIdentification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 1(a)</terms:source>
        <rdfs:comment xml:lang="en">Biometric verification that confirms a person is who they claim to be is excluded.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Verification Exclusion</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_CriminalLawEnforcement -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_CriminalLawEnforcement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#LawEnforcement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#DetectingCriminalOffences"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#InvestigatingCriminalOffences"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#ProsecutingCriminalOffences"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_PublicCrimeReporting"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(1)</terms:source>
        <rdfs:comment xml:lang="en">Exception for AI systems authorised by law for detecting, preventing, investigating, or prosecuting criminal offences, subject to appropriate safeguards.</rdfs:comment>
        <rdfs:label xml:lang="en">Criminal Law Enforcement Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_DetectsPatterns -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_DetectsPatterns">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskException"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#DecisionPatternDetection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_NotReplacingHumanAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">The AI system detects decision-making patterns or deviations from prior decision-making patterns and is not meant to replace or influence the previously completed human assessment without proper human review.</rdfs:comment>
        <rdfs:label xml:lang="en">Detects Decision-Making Patterns Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_FinancialFraudDetection -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_FinancialFraudDetection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#FinancialFraudDetection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 5(b)</terms:source>
        <rdfs:comment xml:lang="en">Exception when the creditworthiness evaluation is used for detecting financial fraud.</rdfs:comment>
        <rdfs:label xml:lang="en">Financial Fraud Detection Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_FreeOpenLicenceGPAI -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_FreeOpenLicenceGPAI">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_NotSystemic"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSystem"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/airco#FreeOpenLicenceGPAIModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(2)</terms:source>
        <rdfs:comment xml:lang="en">Free and open licence GPAI models only need to comply with the Copyright Policy and Training Summary obligations, unless the model is systemic.</rdfs:comment>
        <rdfs:label xml:lang="en">Free Open Licence AI Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_HumanEditorialReview -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_HumanEditorialReview">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_EditorialResponsibility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_MeaningfulHumanReview"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">Exception where the AI-generated content has undergone meaningful human editorial review and a natural or legal person holds editorial responsibility for the publication.</rdfs:comment>
        <rdfs:label xml:lang="en">Human Editorial Review Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_ImprovesHumanResult -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_ImprovesHumanResult">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskException"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HumanResultImprovement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">The AI system improves the result of a previously completed human activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Improves Human Result Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_LabellingFilteringLawfulDatasets -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_LabellingFilteringLawfulDatasets">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_LawfullyAcquiredDataset"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(c)</terms:source>
        <rdfs:comment xml:lang="en">Exception for labelling or filtering of lawfully acquired biometric datasets.</rdfs:comment>
        <rdfs:label xml:lang="en">Labelling or Filtering Lawfully Acquired Datasets Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_LawEnforcementBiometricCategorisation -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_LawEnforcementBiometricCategorisation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#LawEnforcement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(c)</terms:source>
        <rdfs:comment xml:lang="en">Exception when law enforcement categorises biometric data.</rdfs:comment>
        <rdfs:label xml:lang="en">Law Enforcement Biometric Categorisation Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_MedicalReasons -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_MedicalReasons">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#affectsArea"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Health"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(g)</terms:source>
        <rdfs:comment xml:lang="en">Exception when AI action (e.g. emotion inference) is performed for medical reasons.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Reasons Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_NarrowProceduralTask -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_NarrowProceduralTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskException"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#NarrowProceduralTask"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">The AI system performs a narrow procedural task.</rdfs:comment>
        <rdfs:label xml:lang="en">Narrow Procedural Task Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_NoSubstantialAlteration -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_NoSubstantialAlteration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(2)</terms:source>
        <rdfs:comment xml:lang="en">Exception for AI systems that do not substantially alter the input data provided by the deployer or the semantics thereof.</rdfs:comment>
        <rdfs:label xml:lang="en">No Substantial Alteration Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_PoliticalCampaignTools -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_PoliticalCampaignTools">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PoliticalCampaignOrganisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 8(b)</terms:source>
        <rdfs:comment xml:lang="en">Exception for AI outputs that do not directly interact with people, like tools used to organise, optimise, and structure political campaigns.</rdfs:comment>
        <rdfs:label xml:lang="en">Political Campaign Tool Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_PreparatoryTask -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_PreparatoryTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskException"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PreparatoryTask"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">The AI system performs a preparatory task to an assessment relevant for the purpose of the Annex III use cases.</rdfs:comment>
        <rdfs:label xml:lang="en">Preparatory Task Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_ProfilingOverride -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_ProfilingOverride">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Profiling"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#isExceptionTo"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskException"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">AI systems listed under Annex III are always considered high risk if they profile individuals, i.e. automated processing of personal data to assess various aspects of a person&apos;s life.</rdfs:comment>
        <rdfs:label xml:lang="en">Profiling Always High-Risk Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_PublicCrimeReporting -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_PublicCrimeReporting">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <terms:source xml:lang="en">EU AI Act, Article 50(1)</terms:source>
        <rdfs:comment xml:lang="en">Exception for when systems are available for the public to report a criminal offence.</rdfs:comment>
        <rdfs:label xml:lang="en">Public Crime Reporting Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_RemoteBiometricIdentification_ImminentThreat -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_ImminentThreat">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(h)(ii)</terms:source>
        <rdfs:comment xml:lang="en">Exception for preventing substantial and imminent threat to life, or foreseeable terrorist attack.</rdfs:comment>
        <rdfs:label xml:lang="en">Preventing Imminent Threat to Life or Terrorist Attack RBI Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_RemoteBiometricIdentification_MissingPersons -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_MissingPersons">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#AbductionVictim"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#MissingPerson"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SexualExploitationVictim"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TraffickingVictim"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(h)(i)</terms:source>
        <rdfs:comment xml:lang="en">Exception for searching for missing persons, abduction victims, and people who have been human trafficked or sexually exploited.</rdfs:comment>
        <rdfs:label xml:lang="en">Searching Missing Persons RBI Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_RemoteBiometricIdentification_SeriousCrimeSuspects -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_SeriousCrimeSuspects">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Suspect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#includesCrimeType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SeriousCrime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(h)(iii)</terms:source>
        <rdfs:comment xml:lang="en">Exception for identifying suspects in serious crimes.</rdfs:comment>
        <rdfs:label xml:lang="en">Identifying Suspects in Serious Crimes RBI Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyAuthorisation -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyAuthorisation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <terms:source xml:lang="en">EU AI Act, Article 5(4)</terms:source>
        <rdfs:comment xml:lang="en">In duly justified cases of urgency, deployment of remote biometric identification can commence without authorisation, provided that authorisation is requested within 24 hours. If rejected, deployment must cease immediately, deleting all data, results, and outputs.</rdfs:comment>
        <rdfs:label xml:lang="en">Urgency Authorisation RBI Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyRegistration -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyRegistration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <terms:source xml:lang="en">EU AI Act, Article 5(3)</terms:source>
        <rdfs:comment xml:lang="en">In duly justified cases of urgency, deployment of remote biometric identification can commence without registration, provided that it is registered later without undue delay.</rdfs:comment>
        <rdfs:label xml:lang="en">Urgency Registration RBI Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_SafetyReasons -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_SafetyReasons">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#affectsArea"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Safety"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(g)</terms:source>
        <rdfs:comment xml:lang="en">Exception when AI action (e.g. emotion inference) is performed for safety reasons.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Reasons Exception</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Exception_TravelDocumentVerification -->

    <owl:Class rdf:about="https://w3id.org/airco#Exception_TravelDocumentVerification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#VerifyingAuthenticityOfTravelDocument"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 7(d)</terms:source>
        <rdfs:comment xml:lang="en">Exception for verifying travel documents.</rdfs:comment>
        <rdfs:label xml:lang="en">Travel Document Verification Exclusion</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#FacialImageData -->

    <owl:Class rdf:about="https://w3id.org/airco#FacialImageData">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#BiometricData"/>
        <rdfs:comment xml:lang="en">Facial image data.</rdfs:comment>
        <rdfs:label xml:lang="en">Facial Image Data</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#FinancialFraudDetection -->

    <owl:Class rdf:about="https://w3id.org/airco#FinancialFraudDetection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#Detection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#PrivateService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Detection of financial fraud, which exempts creditworthiness evaluation from high-risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">Financial Fraud Detection</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#FreeOpenLicence -->

    <owl:Class rdf:about="https://w3id.org/airco#FreeOpenLicence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#License"/>
        <rdfs:comment xml:lang="en">A free and open licence under which model parameters, weights, architecture, and usage are publicly available, allowing access, usage, modification, and distribution.</rdfs:comment>
        <rdfs:label xml:lang="en">Free and Open Licence</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#FreeOpenLicenceGPAIModel -->

    <owl:Class rdf:about="https://w3id.org/airco#FreeOpenLicenceGPAIModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#GPAIModel"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#hasLicense"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#FreeOpenLicence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#hasStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(2)</terms:source>
        <rdfs:comment xml:lang="en">A GPAI model whose parameters, weights, architecture, and usage are publicly available.</rdfs:comment>
        <rdfs:label xml:lang="en">Free and Open Licence GPAI Model</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#FundamentalRightsImpactAssessment -->

    <owl:Class rdf:about="https://w3id.org/airco#FundamentalRightsImpactAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Documentation"/>
        <rdfs:comment xml:lang="en">A fundamental rights impact assessment required before deployment of real-time RemoteBiometricIdentification.</rdfs:comment>
        <rdfs:label xml:lang="en">Fundamental Rights Impact Assessment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53</terms:source>
        <rdfs:comment xml:lang="en">An obligation placed on providers of GPAI models.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_ComplianceDemonstration -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_ComplianceDemonstration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_CodesOfPracticeParticipation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_CodesOfPracticeScope"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#followsCodeOfConduct"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airo#CodeOfConduct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 56</terms:source>
        <rdfs:comment xml:lang="en">All GPAI model providers may demonstrate compliance by voluntarily adhering to a code of practice until European harmonised standards are published. Providers that don&apos;t adhere must demonstrate alternative adequate means of compliance for Commission approval.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Compliance Demonstration via Codes of Practice Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_CooperateWithHighRisk -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_CooperateWithHighRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(4)</terms:source>
        <rdfs:comment xml:lang="en">GPAI system providers should cooperate with high-risk AI system providers to enable the latter&apos;s compliance.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Cooperation with High-Risk AI Providers Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_CopyrightPolicy -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_CopyrightPolicy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_FreeOpenLicenceGPAI"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#CopyrightPolicy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#compliesWithRegulation"/>
                <owl:hasValue rdf:resource="https://w3id.org/airco#CopyrightDirective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(1)(c)</terms:source>
        <rdfs:comment xml:lang="en">All providers of GPAI models must establish a policy to respect the Copyright Directive.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Copyright Policy Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_Cybersecurity -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_Cybersecurity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SystemicRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#CybersecurityProtection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 55(1)(d)</terms:source>
        <rdfs:comment xml:lang="en">All providers of systemic GPAI models must ensure an adequate level of cybersecurity protection.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Cybersecurity Protection Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_DownstreamProviderInfo -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_DownstreamProviderInfo">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_FreeOpenLicenceGPAI"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#DownstreamProviderDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(1)(b)</terms:source>
        <rdfs:comment xml:lang="en">All providers of GPAI models must draw up information and documentation to supply to downstream providers that intend to integrate the GPAI model into their own AI system, so the latter understands capabilities and limitations and is enabled to comply.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Downstream Provider Information Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_ModelEvaluation -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_ModelEvaluation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SystemicRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ModelEvaluation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 55(1)(a)</terms:source>
        <rdfs:comment xml:lang="en">All providers of systemic GPAI models must perform model evaluations, including conducting and documenting adversarial testing to identify and mitigate systemic risk.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Model Evaluation for Systemic Risk Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_SeriousIncidentReporting -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_SeriousIncidentReporting">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SystemicRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#AIOffice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SeriousIncidentReporting"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 55(1)(c)</terms:source>
        <rdfs:comment xml:lang="en">All providers of systemic GPAI models must track, document, and report serious incidents and possible corrective measures to the AI Office and relevant national competent authorities without undue delay.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Serious Incident Reporting Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_SystemicRiskMitigation -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_SystemicRiskMitigation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SystemicRiskObligation"/>
        <terms:source xml:lang="en">EU AI Act, Article 55(1)(b)</terms:source>
        <rdfs:comment xml:lang="en">All providers of systemic GPAI models must assess and mitigate possible systemic risks, including their sources.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Systemic-Risk Assessment and Mitigation Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_SystemicRiskNotification -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_SystemicRiskNotification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SystemicRiskObligation"/>
        <terms:source xml:lang="en">EU AI Act, Article 51(2)</terms:source>
        <rdfs:comment xml:lang="en">All providers of systemic GPAI models must notify the Commission if their model meets the systemic risk criterion within 2 weeks.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Systemic-Risk Notification Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_TechnicalDocumentation -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_TechnicalDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_FreeOpenLicenceGPAI"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#TechnicalDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(1)(a)</terms:source>
        <rdfs:comment xml:lang="en">All providers of GPAI models must draw up technical documentation, including training and testing process and evaluation results.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Technical Documentation Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIObligation_TrainingSummary -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIObligation_TrainingSummary">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAIObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TrainingSummary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(1)(d)</terms:source>
        <rdfs:comment xml:lang="en">All providers of GPAI models must publish a sufficiently detailed summary about the content used for training the GPAI model.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Training Summary Publication Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AIProvider"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_ComplianceDemonstration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_CooperateWithHighRisk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_CopyrightPolicy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_DownstreamProviderInfo"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_TechnicalDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_TrainingSummary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>EU AI Act, Article 53(1)</terms:source>
        <rdfs:comment xml:lang="en">A provider of a GPAI model subject to all standard GPAI obligations: technical documentation, information and documentation to supply to downstream
providers, respect the Copyright Directive, sufficiently detailed summary about the content used for training .</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAIRiskCategory -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAIRiskCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#RiskCategory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggeredByRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airo#GPAIModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Chapter V, Articles 51-56</terms:source>
        <rdfs:comment xml:lang="en">The General Purpose AI Risk category in the AI Act relating to obligations and risks in GPAI systems.</rdfs:comment>
        <rdfs:label xml:lang="en">GPAI Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GPAISystemicRisk -->

    <owl:Class rdf:about="https://w3id.org/airco#GPAISystemicRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#SystemRiskSource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#isRiskSourceFor"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SystemicRiskGPAIModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 51(1)</terms:source>
        <rdfs:comment xml:lang="en">A systemic risk posed by a GPAI model.</rdfs:comment>
        <rdfs:label xml:lang="en">Systemic Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#GeneratingTextContent -->

    <owl:Class rdf:about="https://w3id.org/airco#GeneratingTextContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#ContentGeneration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToContentType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SyntheticTextContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Purpose of generating synthetic text content.</rdfs:comment>
        <rdfs:label xml:lang="en">Generating Text Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighComputeTraining -->

    <owl:Class rdf:about="https://w3id.org/airco#HighComputeTraining">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAISystemicRisk"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasComputeThreshold"/>
                <owl:hasValue>10^25 FLOPs</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 51(2)</terms:source>
        <rdfs:comment xml:lang="en">Indicates that the GPAI model was trained using compute exceeding the systemic-risk threshold (10^25 FLOPs).</rdfs:comment>
        <rdfs:label xml:lang="en">High-Compute Training</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighImpactCapability -->

    <owl:Class rdf:about="https://w3id.org/airco#HighImpactCapability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GPAISystemicRisk"/>
        <terms:source xml:lang="en">EU AI Act, Article 51(1)(a)</terms:source>
        <rdfs:comment xml:lang="en">Indicates that a GPAI model has high impact capabilities evaluated on the basis of appropriate technical tools and methodologies, including indicators and benchmarks.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Impact Capability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskAIProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskAIProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AIProvider"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_AccuracyRobustnessCybersecurity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_DataGovernance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_DocumentNonHighRiskAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_HumanOversight"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_InstructionsForUse"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_QualityManagementSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_RecordKeeping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_RiskManagementSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskObligation_TechnicalDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A provider of a high-risk AI system, subject to obligations regarding high-risk systems.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk AI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskCategory -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#RiskCategory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggeredByRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskUseCase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Chapter III, Articles 6-27, Annex III</terms:source>
        <rdfs:comment xml:lang="en">The High-Risk category in the AI Act relating to high-risk AI systems.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskException -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskException">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Exception"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_ProfilingOverride"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#isExceptionTo"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskUseCaseAnnexIII"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(3)</terms:source>
        <rdfs:comment xml:lang="en">A criterion that may exempt an AI system from high-risk classification under Annex III. These exceptions are overridden when profiling is involved.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk Exception Criterion</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Obligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Articles 6, 8-17</terms:source>
        <rdfs:comment xml:lang="en">An obligation placed on providers of high-risk AI systems.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_AccuracyRobustnessCybersecurity -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_AccuracyRobustnessCybersecurity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <terms:source xml:lang="en">EU AI Act, Article 15</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must design their high-risk AI system to achieve appropriate levels of accuracy, robustness, and cybersecurity.</rdfs:comment>
        <rdfs:label xml:lang="en">Accuracy, Robustness, and Cybersecurity Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_DataGovernance -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_DataGovernance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#DataGovernance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 10</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must conduct data governance ensuring that training, validation, and testing datasets are relevant, sufficiently representative, and to the best extent possible, free of errors and complete according to the intended purpose.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Governance Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_DocumentNonHighRiskAssessment -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_DocumentNonHighRiskAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <terms:source xml:lang="en">EU AI Act, Article 6(4)</terms:source>
        <rdfs:comment xml:lang="en">Providers whose AI system falls under Annex III use cases but believes it is not high risk must document such an assessment before placing it on the market or putting it into service.</rdfs:comment>
        <rdfs:label xml:lang="en">Document Non-High-Risk Assessment Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_HumanOversight -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_HumanOversight">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#HumanOversightMeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 14</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must design their high-risk AI system to allow deployers to implement human oversight.</rdfs:comment>
        <rdfs:label xml:lang="en">Human Oversight Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_InstructionsForUse -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_InstructionsForUse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#InstructionForUse"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 13</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must provide instructions for use to downstream deployers to enable the latter&apos;s compliance.</rdfs:comment>
        <rdfs:label xml:lang="en">Instructions for Use Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_QualityManagementSystem -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_QualityManagementSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#QualityManagementSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 17</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must establish a quality management system to ensure compliance.</rdfs:comment>
        <rdfs:label xml:lang="en">Quality Management System Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_RecordKeeping -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_RecordKeeping">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#RecordKeepingCapability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 12</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must design their high-risk AI system for record-keeping to enable automatic recording of events relevant for identifying national-level risks and substantial modifications throughout the system&apos;s lifecycle.</rdfs:comment>
        <rdfs:label xml:lang="en">Record-Keeping Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_RiskManagementSystem -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_RiskManagementSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresRiskControl"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#RiskManagementSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 9</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must establish a risk management system throughout the high-risk AI system&apos;s lifecycle.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Management System Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskObligation_TechnicalDocumentation -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskObligation_TechnicalDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#requiresDocumentation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#TechnicalDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 11</terms:source>
        <rdfs:comment xml:lang="en">High-risk AI providers must draw up technical documentation to demonstrate compliance and provide authorities with the information to assess that compliance.</rdfs:comment>
        <rdfs:label xml:lang="en">Technical Documentation Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#UseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">High-Risk AI practice.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCaseAnnexIII -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCaseAnnexIII">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_DetectsPatterns"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_ImprovesHumanResult"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_NarrowProceduralTask"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_PreparatoryTask"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(2), Annex III</terms:source>
        <rdfs:comment xml:lang="en">AI systems listed under Annex III use cases are high risk, subject to exceptions.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk Use Case under Annex III Legislation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase_AssessingEducationLevel -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase_AssessingEducationLevel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCaseAnnexIII"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Education"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#AssessingAccessibleLevelOfEducation"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#AssessingLevelOfEducation"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 3(c)</terms:source>
        <rdfs:comment xml:lang="en">Assessing the appropriate level of education for an individual.</rdfs:comment>
        <rdfs:label xml:lang="en">Assessing Appropriate Level of Education High-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase_BiometricCategorisationSensitive -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase_BiometricCategorisationSensitive">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCaseAnnexIII"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#BiometricCategorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#SensitiveAttributeInference"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToInput"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#BiometricData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#infersSensitiveAttribute"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#SensitiveAttribute"/>
                            <owl:Class>
                                <owl:complementOf>
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/airco#PhilosophicalBeliefs"/>
                                            <rdf:Description rdf:about="https://w3id.org/airco#PoliticalOpinions"/>
                                            <rdf:Description rdf:about="https://w3id.org/airco#Race"/>
                                            <rdf:Description rdf:about="https://w3id.org/airco#ReligiousBeliefs"/>
                                            <rdf:Description rdf:about="https://w3id.org/airco#SexLife"/>
                                            <rdf:Description rdf:about="https://w3id.org/airco#SexualOrientation"/>
                                            <rdf:Description rdf:about="https://w3id.org/airco#TradeUnionMembership"/>
                                        </owl:unionOf>
                                    </owl:Class>
                                </owl:complementOf>
                            </owl:Class>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 1(b)</terms:source>
        <rdfs:comment xml:lang="en">Biometric categorisation systems inferring sensitive or protected attributes or characteristics.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Categorisation Inferring Sensitive Attributes High-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase_Creditworthiness -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase_Creditworthiness">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCaseAnnexIII"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#PrivateService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
