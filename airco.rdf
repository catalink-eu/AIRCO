                            <rdf:Description rdf:about="https://w3id.org/vair#EvaluatingJobInterview"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#JobApplicationAnalysis"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#JobApplicationFiltering"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#JobApplicationScreening"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#PlacingTargetedJobAdvert"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#Recruiting"/>
