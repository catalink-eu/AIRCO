                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#AssessingRiskOfOffending"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#AssessingRiskOfReoffending"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 6(d)</terms:source>
        <rdfs:comment xml:lang="en">Assessing an individual&apos;s risk of offending or re-offending, not solely based on profiling or assessing personality traits or past criminal behaviour.</rdfs:comment>
        <rdfs:label xml:lang="en">Offending or Re-offending Risk Assessment High-Risk Use Case</rdfs:label>
    </owl:Class>
    


