    <owl:Class rdf:about="https://w3id.org/airco#ModelEvaluation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">Model evaluations including adversarial testing to identify and mitigate systemic risk.</rdfs:comment>
