                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#JobApplicant"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#JobCandidate"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#PotentialJobApplicant"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 4(a)</terms:source>
        <rdfs:comment xml:lang="en">AI systems used for recruitment or selection, particularly targeted job ads, analysing and filtering applications, and evaluating candidates.</rdfs:comment>
        <rdfs:label xml:lang="en">Recruitment and Selection High-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase_RemoteBiometricIdentification -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase_RemoteBiometricIdentification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCaseAnnexIII"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#BiometricIdentification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#RemoteIdentification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_BiometricVerification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 1(a)</terms:source>
        <rdfs:comment xml:lang="en">Remote biometric identification systems, excluding biometric verification that confirms a person is who they claim to be.</rdfs:comment>
        <rdfs:label xml:lang="en">Remote Biometric Identification High-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase_SafetyComponentAnnexI -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase_SafetyComponentAnnexI">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_SafetyComponentOrProduct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_ThirdPartyConformityAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 6(1)</terms:source>
        <rdfs:comment xml:lang="en">AI system used as a safety component or a product covered by EU laws in Annex I and required to undergo a third-party conformity assessment under those Annex I laws.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Component Under Annex I Legislation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HumanResultImprovement -->

    <owl:Class rdf:about="https://w3id.org/airco#HumanResultImprovement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AICapability"/>
        <rdfs:comment xml:lang="en">The capability of an AI system to improve the result of a previously completed human activity without replacing the human decision.</rdfs:comment>
        <rdfs:label xml:lang="en">Human Result Improvement Capability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#IllegalWeaponsTrafficking -->

    <owl:Class rdf:about="https://w3id.org/airco#IllegalWeaponsTrafficking">
