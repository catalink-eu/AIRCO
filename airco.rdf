            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskUseCase_RemoteBiometricIdentification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers UseCase_RemoteBiometricIdentification.</rdfs:comment>
        <rdfs:label xml:lang="en">Remote Biometric Identification System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_SocialScoring -->

    <owl:Class rdf:about="https://w3id.org/airco#System_SocialScoring">
        <owl:equivalentClass>
