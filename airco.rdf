    </owl:Class>
    


    <!-- https://w3id.org/airco#NarcoticTrafficking -->

    <owl:Class rdf:about="https://w3id.org/airco#NarcoticTrafficking">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SeriousCrime"/>
        <rdfs:label xml:lang="en">Narcotic Trafficking</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#NarrowProceduralTask -->

    <owl:Class rdf:about="https://w3id.org/airco#NarrowProceduralTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AICapability"/>
        <rdfs:comment xml:lang="en">The capability of an AI system to perform only a narrow, procedural task with limited scope.</rdfs:comment>
        <rdfs:label xml:lang="en">Narrow Procedural Task Capability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#NationalCompetentAuthority -->

    <owl:Class rdf:about="https://w3id.org/airco#NationalCompetentAuthority">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Stakeholder"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIObligation_SeriousIncidentReporting"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A national competent authority to which serious incidents must be reported.</rdfs:comment>
        <rdfs:label xml:lang="en">National Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#NotificationRequirement -->

    <owl:Class rdf:about="https://w3id.org/airco#NotificationRequirement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyObligation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A requirement to notify individuals they are interacting with AI.</rdfs:comment>
        <rdfs:label xml:lang="en">Notification Requirement</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ObjectiveVerifiableFact -->

    <owl:Class rdf:about="https://w3id.org/airco#ObjectiveVerifiableFact">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Input"/>
        <rdfs:comment xml:lang="en">Objective, verifiable facts directly linked to criminal activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Objective Verifiable Fact</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Obligation -->

    <owl:Class rdf:about="https://w3id.org/airco#Obligation">
        <rdfs:comment xml:lang="en">A specific obligation imposed on a stakeholder by the AI Act.</rdfs:comment>
        <rdfs:label xml:lang="en">Obligation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#OrganisedCrime -->

    <owl:Class rdf:about="https://w3id.org/airco#OrganisedCrime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SeriousCrime"/>
        <rdfs:label xml:lang="en">Organised Crime</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PatternRecognition -->

    <owl:Class rdf:about="https://w3id.org/airco#PatternRecognition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AICapability"/>
        <rdfs:comment xml:lang="en">The capability of an AI system to identify, detect, or analyse patterns in data or human behaviour, including decision-making patterns.</rdfs:comment>
        <rdfs:label xml:lang="en">Pattern Recognition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PersonalData -->

    <owl:Class rdf:about="https://w3id.org/airco#PersonalData">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Input"/>
        <rdfs:comment xml:lang="en">Personal data of natural persons.</rdfs:comment>
        <rdfs:label xml:lang="en">Personal Data</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PersonalTraitData -->

    <owl:Class rdf:about="https://w3id.org/airco#PersonalTraitData">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#PersonalData"/>
        <rdfs:comment xml:lang="en">Data about personal or personality traits.</rdfs:comment>
        <rdfs:label xml:lang="en">Personal Trait Data</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PhilosophicalBeliefs -->

    <owl:Class rdf:about="https://w3id.org/airco#PhilosophicalBeliefs">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Philosophical Beliefs</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PoliticalCampaignOrganisation -->

    <owl:Class rdf:about="https://w3id.org/airco#PoliticalCampaignOrganisation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Purpose"/>
        <rdfs:comment xml:lang="en">Use of AI tools to organise, optimise, and structure political campaigns without directly interacting with people.</rdfs:comment>
        <rdfs:label xml:lang="en">Political Campaign Organisation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PoliticalOpinions -->

    <owl:Class rdf:about="https://w3id.org/airco#PoliticalOpinions">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Political Opinions</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PreDeploymentCondition -->

    <owl:Class rdf:about="https://w3id.org/airco#PreDeploymentCondition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Condition"/>
        <rdfs:comment xml:lang="en">A condition that must be met before deployment.</rdfs:comment>
        <rdfs:label xml:lang="en">Pre-Deployment Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PreparatoryTask -->

    <owl:Class rdf:about="https://w3id.org/airco#PreparatoryTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AICapability"/>
        <rdfs:comment xml:lang="en">The capability of an AI system to perform a preparatory task to an assessment relevant for high-risk use cases, without making the assessment itself.</rdfs:comment>
        <rdfs:label xml:lang="en">Preparatory Task Capability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedCategory -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#RiskCategory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggeredByRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Chapter II, Article 5</terms:source>
        <rdfs:comment xml:lang="en">The Prohibited-Risk category in the AI Act relating to prohibited AI systems.</rdfs:comment>
        <rdfs:label xml:lang="en">Prohibited Category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedSensitiveAttributes -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedSensitiveAttributes">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SensitiveAttribute"/>
        <rdfs:comment xml:lang="en">A sensitive personal attribute whose inference from biometric data is prohibited under the EU AI Act.</rdfs:comment>
        <rdfs:label xml:lang="en">Prohibited Sensitive Attribute</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#UseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ProhibitedCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Prohibited AI practice.</rdfs:comment>
        <rdfs:label xml:lang="en">Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_BiometricCategorisationProhibitedSensitive -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_BiometricCategorisationProhibitedSensitive">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#BiometricCategorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#SensitiveAttributeInference"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToInput"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#BiometricData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_LabellingFilteringLawfulDatasets"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_LawEnforcementBiometricCategorisation"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#infersSensitiveAttribute"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#PhilosophicalBeliefs"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#PoliticalOpinions"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Race"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#ReligiousBeliefs"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SexLife"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SexualOrientation"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#TradeUnionMembership"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(g)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on biometric categorisation systems inferring the race, political opinions, trade union membership, religious or philosophical beliefs, sex life, or sexual orientation of a natural person.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Categorisation Inferring Prohibited Sensitive Attributes Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_CriminalRiskProfiling -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_CriminalRiskProfiling">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Profiling"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToInput"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#PersonalTraitData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#PredictingRiskOfOffending"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_SolelyBasedOnProfiling"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_AugmentingHumanAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(d)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on assessing the risk of an individual committing criminal offenses solely based on profiling or personality traits.</rdfs:comment>
        <rdfs:label xml:lang="en">Criminal Risk Assessment Solely Based on Profiling Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_EmotionInferenceWorkplaceEducation -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_EmotionInferenceWorkplaceEducation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#EmotionRecognition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#EmotionInferenceInEducation"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#EmotionInferenceInWorkplace"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_MedicalReasons"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_SafetyReasons"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(f)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on inferring emotions in workplaces or educational institutions, except for medical or safety reasons.</rdfs:comment>
        <rdfs:label xml:lang="en">Inferring Emotions in Workplaces and Educational Institutions Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_ExploitingVulnerabilities -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_ExploitingVulnerabilities">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#VulnerableGroup"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#VulnerablePerson"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#causesConsequence"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#ExploitationOfVulnerability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#causesConsequence"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#MaterialDistortionOfBehaviour"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#causesImpact"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Harm"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#exploitsVulnerabilityType"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#AgeVulnerability"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#DisabilityVulnerability"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SocioEconomicVulnerability"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(b)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on AI systems exploiting vulnerabilities related to age, disability, or socio-economic circumstances to distort behaviour, causing significant harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Exploiting Vulnerabilities Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_FacialRecognitionDatabaseScraping -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_FacialRecognitionDatabaseScraping">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#FaceRecognition"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#WebScraping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToInput"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#FacialImageData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#CreatingFacialRecognitionDatabase"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#ExpandingFacialRecognitionDatabase"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasDataSource"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#CCTVFootage"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#ScrapedFacialImages"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(e)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on compiling facial recognition databases by untargeted scraping of facial images from the internet or CCTV footage.</rdfs:comment>
        <rdfs:label xml:lang="en">Compiling Facial Recognition Databases by Untargeted Scraping Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_RealTimeRemoteBiometricIdentification -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_RealTimeRemoteBiometricIdentification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#RealTimeRemoteBiometricIdentification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#LawEnforcement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToLocality"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#PubliclyAccessibleSpace"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#LawEnforcementAuthority"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_ImminentThreat"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_MissingPersons"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#Exception_RemoteBiometricIdentification_SeriousCrimeSuspects"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(h)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on real-time remote biometric identification in publicly accessible spaces for law enforcement.</rdfs:comment>
        <rdfs:label xml:lang="en">Real-Time Remote Biometric Identification in Public Spaces Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_SocialScoring -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_SocialScoring">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToCapability"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#SocialScoring"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToInput"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#PersonalTraitData"/>
                            <rdf:Description rdf:about="https://w3id.org/airco#SocialBehaviourData"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#ClassificationOfPeople"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#EvaluationOfPeople"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#Group"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#NaturalPerson"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#causesImpact"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#DetrimentalTreatment"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#UnfavourableTreatment"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(c)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on evaluating or classifying individuals or groups based on social behaviour or personal traits, causing detrimental or unfavourable treatment.</rdfs:comment>
        <rdfs:label xml:lang="en">Social Scoring Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ProhibitedUseCase_SubliminalManipulativeDeceptive -->

    <owl:Class rdf:about="https://w3id.org/airco#ProhibitedUseCase_SubliminalManipulativeDeceptive">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedUseCase"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#ManipulativePurpose"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToTechnique"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airco#ManipulativeTechnique"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#DeceptiveTechnique"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#SubliminalTechnique"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#causesConsequence"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#ImpairedDecisionMaking"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#MaterialDistortionOfBehaviour"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#causesImpact"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Harm"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 5(1)(a)</terms:source>
        <rdfs:comment xml:lang="en">Prohibition on AI systems deploying subliminal, manipulative, or deceptive techniques to distort behaviour and impair informed decision-making, causing significant harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Subliminal, Manipulative, or Deceptive AI Prohibited Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PublicInterestTextGeneration -->

    <owl:Class rdf:about="https://w3id.org/airco#PublicInterestTextGeneration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#GeneratingTextContent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToContentType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#SyntheticTextContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#NaturalPerson"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Generation of AI text published to inform the public on matters of public interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Public Interest Text Generation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#PublicInterestTextGenerationAIDeployer -->

    <owl:Class rdf:about="https://w3id.org/airco#PublicInterestTextGenerationAIDeployer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskAIDeployer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyObligation_PublicInterestTextGenerationDisclosure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(4)</terms:source>
        <rdfs:comment xml:lang="en">A deployer of an AI system generating or manipulating text published with the purpose of informing the public on matters of public interest, subject to transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Public Interest Text Generation AI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#QualityManagementSystem -->

    <owl:Class rdf:about="https://w3id.org/airco#QualityManagementSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">A quality management system to ensure compliance.</rdfs:comment>
        <rdfs:label xml:lang="en">Quality Management System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Race -->

    <owl:Class rdf:about="https://w3id.org/airco#Race">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Race</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Rape -->

    <owl:Class rdf:about="https://w3id.org/airco#Rape">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#SeriousCrime"/>
        <rdfs:label xml:lang="en">Rape</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#RecordKeepingCapability -->

    <owl:Class rdf:about="https://w3id.org/airco#RecordKeepingCapability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">Design for automatic record-keeping of events relevant for identifying risks and modifications.</rdfs:comment>
        <rdfs:label xml:lang="en">Record Keeping Capability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#RegulatoryDatabase -->

    <owl:Class rdf:about="https://w3id.org/airco#RegulatoryDatabase">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Database"/>
        <rdfs:comment xml:lang="en">A database established by a regulatory authority for registration, tracking, or compliance purposes.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Database</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ReligiousBeliefs -->

    <owl:Class rdf:about="https://w3id.org/airco#ReligiousBeliefs">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Religious Beliefs</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#RiskCategory -->

    <owl:Class rdf:about="https://w3id.org/airco#RiskCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskConcept"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSystem"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/airo#AIModel"/>
                            <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A risk classification level under the EU AI Act.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#RiskManagementSystem -->

    <owl:Class rdf:about="https://w3id.org/airco#RiskManagementSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">A risk management system established throughout the high-risk AI system&apos;s lifecycle.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Management System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ScientificPanelOfExperts -->

    <owl:Class rdf:about="https://w3id.org/airco#ScientificPanelOfExperts">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Stakeholder"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasCondition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Condition_HighImpactCapabilitiesOverride"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The scientific panel of independent experts that can issue qualified alerts.</rdfs:comment>
        <rdfs:label xml:lang="en">Scientific Panel Of Experts</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#ScrapedFacialImages -->

    <owl:Class rdf:about="https://w3id.org/airco#ScrapedFacialImages">
        <rdfs:subClassOf rdf:resource="https://w3id.org/dpv#SensitiveData"/>
        <rdfs:comment xml:lang="en">Untargeted scraping of facial images from the internet.</rdfs:comment>
        <rdfs:label xml:lang="en">Internet Scraping</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SensitiveAttribute -->

    <owl:Class rdf:about="https://w3id.org/airco#SensitiveAttribute">
        <rdfs:comment xml:lang="en">A sensitive personal attribute protected under the AI Act.</rdfs:comment>
        <rdfs:label xml:lang="en">Sensitive Attribute</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SeriousCrime -->

    <owl:Class rdf:about="https://w3id.org/airco#SeriousCrime">
        <rdfs:comment xml:lang="en">A category of serious criminal offence referenced in remote biometric identification exceptions.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Crime</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SeriousIncidentReporting -->

    <owl:Class rdf:about="https://w3id.org/airco#SeriousIncidentReporting">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#RiskControl"/>
        <rdfs:comment xml:lang="en">Tracking, documenting, and reporting serious incidents and possible corrective measures.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident Reporting</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SexLife -->

    <owl:Class rdf:about="https://w3id.org/airco#SexLife">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Sex Life</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SexualExploitationVictim -->

    <owl:Class rdf:about="https://w3id.org/airco#SexualExploitationVictim">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#Victim"/>
        <rdfs:comment xml:lang="en">A person who has been sexually exploited and is the subject of a search using real-time remote biometric identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Sexual Exploitation Victim</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SexualOrientation -->

    <owl:Class rdf:about="https://w3id.org/airco#SexualOrientation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#ProhibitedSensitiveAttributes"/>
        <rdfs:label xml:lang="en">Sexual Orientation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SocialBehaviourData -->

    <owl:Class rdf:about="https://w3id.org/airco#SocialBehaviourData">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#PersonalData"/>
        <rdfs:comment xml:lang="en">Data about an individual&apos;s social behaviour.</rdfs:comment>
        <rdfs:label xml:lang="en">Social Behaviour Data</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SocioEconomicVulnerability -->

    <owl:Class rdf:about="https://w3id.org/airco#SocioEconomicVulnerability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#Vulnerability"/>
        <rdfs:label xml:lang="en">Socio-Economic Vulnerability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#StandardGPAIModel -->

    <owl:Class rdf:about="https://w3id.org/airco#StandardGPAIModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#GPAIModel"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasLicense"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/airco#FreeOpenLicence"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasRiskCategory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIRiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airo#hasStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GPAIProvider"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 53(1)</terms:source>
        <rdfs:comment xml:lang="en">A GPAI model whose providers are subject to standard GPAI obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Standard GPAI Model</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#Suspect -->

    <owl:Class rdf:about="https://w3id.org/airco#Suspect">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISubject"/>
        <rdfs:comment xml:lang="en">A person suspected of having committed, or of being involved in, a criminal offence.</rdfs:comment>
        <rdfs:label xml:lang="en">Suspect</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SyntheticAudioContent -->

    <owl:Class rdf:about="https://w3id.org/airco#SyntheticAudioContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#Content"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#GeneratingAudioContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Synthetically generated or manipulated audio content.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Audio Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SyntheticContentGenerationAIProvider -->

    <owl:Class rdf:about="https://w3id.org/airco#SyntheticContentGenerationAIProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#TransparencyRiskAIProvider"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasObligation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyObligation_SyntheticContentGenerationMarking"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Article 50(2)</terms:source>
        <rdfs:comment xml:lang="en">A provider of AI system generating synthetic audio, image, video, or text content, subject to transparency obligations.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Content Generation AI Provider</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SyntheticImageContent -->

    <owl:Class rdf:about="https://w3id.org/airco#SyntheticImageContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#Content"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#GeneratingImageContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Synthetically generated or manipulated image content.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Image Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SyntheticTextContent -->

    <owl:Class rdf:about="https://w3id.org/airco#SyntheticTextContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#Content"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#GeneratingTextContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Synthetically generated or manipulated text content.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Text Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#SyntheticVideoContent -->

    <owl:Class rdf:about="https://w3id.org/airco#SyntheticVideoContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/vair#Content"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#GeneratingVideoContent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Synthetically generated or manipulated video content.</rdfs:comment>
        <rdfs:label xml:lang="en">Synthetic Video Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_AssessingEducationLevel -->

    <owl:Class rdf:about="https://w3id.org/airco#System_AssessingEducationLevel">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasPurpose"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/vair#AssessingLevelOfEducation"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#isAppliedWithinDomain"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Education"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskUseCase_AssessingEducationLevel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers UseCase_AssessingEducationLevel.</rdfs:comment>
        <rdfs:label xml:lang="en">Education Level Assessment System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_BiometricCategorisation -->

    <owl:Class rdf:about="https://w3id.org/airco#System_BiometricCategorisation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasCapability"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/vair#BiometricCategorisation"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/airo#AISystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#triggersRegulation"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#TransparencyRiskUseCase_BiometricCategorisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers TransparencyRiskUseCase_BiometricCategorisation.</rdfs:comment>
        <rdfs:label xml:lang="en">Biometric Categorisation System</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#System_BiometricCategorisationSensitive -->

    <owl:Class rdf:about="https://w3id.org/airco#System_BiometricCategorisationSensitive">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/airo#AISystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/airo#hasCapability"/>
