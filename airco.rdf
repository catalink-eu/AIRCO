                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#hasException"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#Exception_TravelDocumentVerification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 7(d)</terms:source>
        <rdfs:comment xml:lang="en">Detecting, recognising, or identifying individuals in migration context, except verifying travel documents.</rdfs:comment>
        <rdfs:label xml:lang="en">Migration Identification of Individuals High-Risk Use Case</rdfs:label>
    </owl:Class>
    


