                <owl:someValuesFrom rdf:resource="https://w3id.org/airco#HighRiskUseCase_RecruitmentSelection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">AI system archetype that triggers UseCase_RecruitmentSelection.</rdfs:comment>
        <rdfs:label xml:lang="en">Recruitment and Selection System</rdfs:label>
    </owl:Class>
    


