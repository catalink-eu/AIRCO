                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#Student"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 3(d)</terms:source>
        <rdfs:comment xml:lang="en">Monitoring and detecting prohibited student behaviour during tests.</rdfs:comment>
        <rdfs:label xml:lang="en">Monitoring Prohibited Student Behaviour During Tests High-Risk Use Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/airco#HighRiskUseCase_PublicBenefitsEligibility -->

    <owl:Class rdf:about="https://w3id.org/airco#HighRiskUseCase_PublicBenefitsEligibility">
        <rdfs:subClassOf rdf:resource="https://w3id.org/airco#HighRiskUseCaseAnnexIII"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToDomain"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#PublicService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToPurpose"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#EvaluatingEligibilityForPublicAssistanceServices"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#GrantingPublicAssistanceServices"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#ReclaimingPublicAssistanceServices"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#ReducingPublicAssistanceServices"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#RevokingPublicAssistanceServices"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToStakeholder"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/vair#PublicAuthority"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/airco#appliesToSubject"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/vair#PotentialPublicServicesApplicant"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#PublicServicesApplicant"/>
                            <rdf:Description rdf:about="https://w3id.org/vair#PublicServicesRecipient"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source xml:lang="en">EU AI Act, Annex III, 5(a)</terms:source>
        <rdfs:comment xml:lang="en">AI systems used by public authorities for assessing eligibility to benefits and services, including their allocation, reduction, revocation, or recovery.</rdfs:comment>
        <rdfs:label xml:lang="en">Public Benefits Eligibility Assessment High-Risk Use Case</rdfs:label>
    </owl:Class>
    


