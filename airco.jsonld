  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception for AI systems that do not substantially alter the input data provided by the deployer or the semantics thereof."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "No Substantial Alteration Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_PoliticalCampaignTools",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Annex III, 8(b)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception for AI outputs that do not directly interact with people, like tools used to organise, optimise, and structure political campaigns."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Political Campaign Tool Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  }, {
    "@id" : "_:genid68"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_PreparatoryTask",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The AI system performs a preparatory task to an assessment relevant for the purpose of the Annex III use cases."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Preparatory Task Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskException"
  }, {
    "@id" : "_:genid69"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_ProfilingOverride",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "AI systems listed under Annex III are always considered high risk if they profile individuals, i.e. automated processing of personal data to assess various aspects of a person's life."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Profiling Always High-Risk Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  }, {
    "@id" : "_:genid70"
  }, {
    "@id" : "_:genid71"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_PublicCrimeReporting",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 50(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception for when systems are available for the public to report a criminal offence."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Public Crime Reporting Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_RemoteBiometricIdentification_ImminentThreat",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(h)(ii)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception for preventing substantial and imminent threat to life, or foreseeable terrorist attack."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Preventing Imminent Threat to Life or Terrorist Attack RBI Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  }, {
