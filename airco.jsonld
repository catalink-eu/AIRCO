  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 51(1)(a)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicates that a GPAI model has high impact capabilities evaluated on the basis of appropriate technical tools and methodologies, including indicators and benchmarks."
