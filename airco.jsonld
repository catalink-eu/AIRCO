}, {
  "@id" : "https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyAuthorisation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In duly justified cases of urgency, deployment of remote biometric identification can commence without authorisation, provided that authorisation is requested within 24 hours. If rejected, deployment must cease immediately, deleting all data, results, and outputs."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Urgency Authorisation RBI Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyRegistration",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In duly justified cases of urgency, deployment of remote biometric identification can commence without registration, provided that it is registered later without undue delay."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Urgency Registration RBI Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Exception_SafetyReasons",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(g)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception when AI action (e.g. emotion inference) is performed for safety reasons."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Safety Reasons Exception"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Exception"
  }, {
