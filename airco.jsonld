  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "EU AI Act, Article 53(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A provider of a GPAI model subject to all standard GPAI obligations: technical documentation, information and documentation to supply to downstream\nproviders, respect the Copyright Directive, sufficiently detailed summary about the content used for training ."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Provider"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#AIProvider"
  }, {
