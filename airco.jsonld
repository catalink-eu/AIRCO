    "@language" : "en",
    "@value" : "EU AI Act, Article 6(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The AI system improves the result of a previously completed human activity."
