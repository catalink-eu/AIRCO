    "@id" : "https://w3id.org/vair#Detection"
  }, {
    "@id" : "_:genid97"
  } ]
}, {
  "@id" : "https://w3id.org/airco#FreeOpenLicence",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A free and open licence under which model parameters, weights, architecture, and usage are publicly available, allowing access, usage, modification, and distribution."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Free and Open Licence"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#License"
  } ]
}, {
  "@id" : "https://w3id.org/airco#FreeOpenLicenceGPAIModel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A GPAI model whose parameters, weights, architecture, and usage are publicly available."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Free and Open Licence GPAI Model"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#GPAIModel"
