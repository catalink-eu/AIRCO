  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(h)(iii)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception for identifying suspects in serious crimes."
