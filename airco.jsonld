    "@value" : "EU AI Act, Annex III, 5(b)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception when the creditworthiness evaluation is used for detecting financial fraud."
