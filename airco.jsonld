    "@value" : "Facial image data."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Facial Image Data"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#BiometricData"
  } ]
}, {
  "@id" : "https://w3id.org/airco#FinancialFraudDetection",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Detection of financial fraud, which exempts creditworthiness evaluation from high-risk classification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Financial Fraud Detection"
  } ],
