  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 51(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicates that the GPAI model was trained using compute exceeding the systemic-risk threshold (10^25 FLOPs)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "High-Compute Training"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAISystemicRisk"
  }, {
    "@id" : "_:genid128"
  } ]
}, {
