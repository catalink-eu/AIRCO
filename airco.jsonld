    "@id" : "https://w3id.org/airco#Exception"
  }, {
    "@id" : "_:genid139"
  }, {
    "@id" : "_:genid140"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Articles 6, 8-17"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An obligation placed on providers of high-risk AI systems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "High-Risk Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Obligation"
  }, {
    "@id" : "_:genid141"
  }, {
    "@id" : "_:genid142"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_AccuracyRobustnessCybersecurity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 15"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must design their high-risk AI system to achieve appropriate levels of accuracy, robustness, and cybersecurity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accuracy, Robustness, and Cybersecurity Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_DataGovernance",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 10"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must conduct data governance ensuring that training, validation, and testing datasets are relevant, sufficiently representative, and to the best extent possible, free of errors and complete according to the intended purpose."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Data Governance Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid143"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_DocumentNonHighRiskAssessment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Providers whose AI system falls under Annex III use cases but believes it is not high risk must document such an assessment before placing it on the market or putting it into service."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Document Non-High-Risk Assessment Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_HumanOversight",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 14"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must design their high-risk AI system to allow deployers to implement human oversight."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Human Oversight Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid144"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_InstructionsForUse",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 13"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must provide instructions for use to downstream deployers to enable the latter's compliance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Instructions for Use Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid145"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_QualityManagementSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 17"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must establish a quality management system to ensure compliance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Quality Management System Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid146"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_RecordKeeping",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 12"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must design their high-risk AI system for record-keeping to enable automatic recording of events relevant for identifying national-level risks and substantial modifications throughout the system's lifecycle."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Record-Keeping Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid147"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_RiskManagementSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 9"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must establish a risk management system throughout the high-risk AI system's lifecycle."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Risk Management System Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid148"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskObligation_TechnicalDocumentation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 11"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk AI providers must draw up technical documentation to demonstrate compliance and provide authorities with the information to assess that compliance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Technical Documentation Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#HighRiskObligation"
  }, {
    "@id" : "_:genid149"
  } ]
}, {
  "@id" : "https://w3id.org/airco#HighRiskUseCase",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-Risk AI practice."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "High-Risk Use Case"
