  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fundamental rights impact assessment required before deployment of real-time RemoteBiometricIdentification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Fundamental Rights Impact Assessment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#Documentation"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GDPR",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "https://w3id.org/airo#Regulation" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Regulation (EU) 2016/679 - General Data Protection Regulation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GDPR"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An obligation placed on providers of GPAI models."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Obligation"
  }, {
    "@id" : "_:genid101"
  }, {
    "@id" : "_:genid102"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_ComplianceDemonstration",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 56"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All GPAI model providers may demonstrate compliance by voluntarily adhering to a code of practice until European harmonised standards are published. Providers that don't adhere must demonstrate alternative adequate means of compliance for Commission approval."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Compliance Demonstration via Codes of Practice Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAIObligation"
  }, {
    "@id" : "_:genid103"
  }, {
    "@id" : "_:genid104"
  }, {
    "@id" : "_:genid105"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_CooperateWithHighRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "GPAI system providers should cooperate with high-risk AI system providers to enable the latter's compliance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Cooperation with High-Risk AI Providers Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAIObligation"
  }, {
    "@id" : "_:genid106"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_CopyrightPolicy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(1)(c)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of GPAI models must establish a policy to respect the Copyright Directive."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Copyright Policy Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAIObligation"
  }, {
    "@id" : "_:genid107"
  }, {
    "@id" : "_:genid108"
  }, {
    "@id" : "_:genid109"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_Cybersecurity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 55(1)(d)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of systemic GPAI models must ensure an adequate level of cybersecurity protection."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Cybersecurity Protection Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#SystemicRiskObligation"
  }, {
    "@id" : "_:genid110"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_DownstreamProviderInfo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(1)(b)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of GPAI models must draw up information and documentation to supply to downstream providers that intend to integrate the GPAI model into their own AI system, so the latter understands capabilities and limitations and is enabled to comply."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Downstream Provider Information Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAIObligation"
  }, {
    "@id" : "_:genid111"
  }, {
    "@id" : "_:genid112"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_ModelEvaluation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 55(1)(a)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of systemic GPAI models must perform model evaluations, including conducting and documenting adversarial testing to identify and mitigate systemic risk."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Model Evaluation for Systemic Risk Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#SystemicRiskObligation"
  }, {
    "@id" : "_:genid113"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_SeriousIncidentReporting",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 55(1)(c)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of systemic GPAI models must track, document, and report serious incidents and possible corrective measures to the AI Office and relevant national competent authorities without undue delay."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Serious Incident Reporting Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#SystemicRiskObligation"
  }, {
    "@id" : "_:genid114"
  }, {
    "@id" : "_:genid115"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_SystemicRiskMitigation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 55(1)(b)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of systemic GPAI models must assess and mitigate possible systemic risks, including their sources."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Systemic-Risk Assessment and Mitigation Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#SystemicRiskObligation"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_SystemicRiskNotification",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 51(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of systemic GPAI models must notify the Commission if their model meets the systemic risk criterion within 2 weeks."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Systemic-Risk Notification Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#SystemicRiskObligation"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_TechnicalDocumentation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(1)(a)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of GPAI models must draw up technical documentation, including training and testing process and evaluation results."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Technical Documentation Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAIObligation"
  }, {
    "@id" : "_:genid116"
  }, {
    "@id" : "_:genid117"
  } ]
}, {
  "@id" : "https://w3id.org/airco#GPAIObligation_TrainingSummary",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(1)(d)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All providers of GPAI models must publish a sufficiently detailed summary about the content used for training the GPAI model."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GPAI Training Summary Publication Obligation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#GPAIObligation"
  }, {
    "@id" : "_:genid118"
  } ]
}, {
