    "@language" : "en",
    "@value" : "EU AI Act, Article 50(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception where the AI-generated content has undergone meaningful human editorial review and a natural or legal person holds editorial responsibility for the publication."
