    "@language" : "en",
    "@value" : "EU AI Act, Article 50(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Exception for AI systems authorised by law for detecting, preventing, investigating, or prosecuting criminal offences, subject to appropriate safeguards."
  } ],
