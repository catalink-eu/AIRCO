  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A criterion that may exempt an AI system from high-risk classification under Annex III. These exceptions are overridden when profiling is involved."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "High-Risk Exception Criterion"
  } ],
