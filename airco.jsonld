    "@value" : "A condition that must be satisfied for a rule or exception to apply."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_CodesOfPracticeParticipation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 56(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "AI Office may invite GPAI model providers, relevant national competent authorities to participate, while civil society, industry, academia, downstream providers, and independent experts may support the process."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Codes of Practice Participation Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid9"
  }, {
    "@id" : "_:genid10"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_CodesOfPracticeScope",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 56(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Codes will cover but not necessarily be limited to: information in technical documentation for authorities and downstream providers, identification of type and nature of systemic risks and their sources, and modalities of risk management."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Codes of Practice Scope Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid15"
  }, {
    "@id" : "_:genid16"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_EditorialResponsibility",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 50(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A natural or legal person must hold editorial responsibility for the publication."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Editorial Responsibility Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_HighImpactCapabilitiesOverride",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 51(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Commission may decide, on its own or via qualified alert from the scientific panel of independent experts, that a model has high impact capabilities, rendering it systemic."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "High Impact Capabilities Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid17"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_HumanAssessmentAugmentation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(e)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "AI must augment rather than replace human assessments."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Human Assessment Augmentation Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_LawfullyAcquiredDataset",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(c)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The biometric dataset must have been lawfully acquired."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Lawfully Acquired Dataset Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid18"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_MeaningfulHumanReview",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 50(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The AI-generated content must have undergone meaningful human editorial review."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Meaningful Human Review Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_NonHamperingDisclosure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 50(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Disclosure must not hamper the display or enjoyment of the work."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Non-Hampering Disclosure Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_NotObviousAI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 50(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Applies unless it is obvious from the point of view of a reasonably well-informed, observant, and circumspect natural person."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Not Obviously AI Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid19"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_NotReplacingHumanAssessment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The AI system must not be meant to replace or influence the previously completed human assessment without proper human review."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Not Replacing Human Assessment Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_NotSystemic",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 53(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "System must not present systemic risks."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Not Systemic Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid20"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_ObjectiveVerifiableFacts",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(e)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Must be based on objective, verifiable facts directly linked to criminal activity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Objective Verifiable Facts Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid22"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Using AI-enabled real-time remote biometric identification must account for affected persons' rights and freedoms."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Account for Rights and Freedoms Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Real-time remote biometric identification is only allowed when not using the tool would cause considerable harm."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Considerable Harm Without Tool Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Police must complete a fundamental rights impact assessment before deployment of remote biometric identification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Fundamental Rights Impact Assessment Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#PreDeploymentCondition"
  }, {
    "@id" : "_:genid23"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(4)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Must obtain authorisation from a judicial authority or independent administrative authority before deployment of remote biometric identification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Obtain Authorisation Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#PreDeploymentCondition"
  }, {
    "@id" : "_:genid24"
  }, {
    "@id" : "_:genid25"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(3)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The system must be registered in the EU database before deployment of remote biometric identification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Register in EU Database Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#PreDeploymentCondition"
  }, {
    "@id" : "_:genid29"
  }, {
    "@id" : "_:genid30"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_SafetyComponentOrProduct",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The AI system must be used as a safety component or be a product covered by EU laws in Annex I."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Safety Component or Product Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_SolelyBasedOnProfiling",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 5(1)(e), Annex III, 6(d)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The assessment must be solely based on profiling or personality traits, without other evidence."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Solely Based on Profiling Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  }, {
    "@id" : "_:genid31"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_TechnicalFeasibility",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 50(2)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Solutions must be effective, interoperable, robust, and reliable as far as technically feasible."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Technical Feasibility Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Condition_ThirdPartyConformityAssessment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU AI Act, Article 6(1)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Must be required to undergo a third-party conformity assessment under Annex I laws."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Third-Party Conformity Assessment Condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airco#Condition"
  } ]
}, {
  "@id" : "https://w3id.org/airco#CopyrightDirective",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "https://w3id.org/airo#Regulation" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The EU Copyright Directive."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Copyright Directive"
  } ]
}, {
  "@id" : "https://w3id.org/airco#CopyrightPolicy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A policy established to respect the Copyright Directive."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Copyright Policy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#Documentation"
  } ]
}, {
  "@id" : "https://w3id.org/airco#CybersecurityProtection",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An adequate level of cybersecurity protection."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cybersecurity Protection"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/vair#SecurityMeasure"
  } ]
}, {
  "@id" : "https://w3id.org/airco#DataGovernance",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Data governance measures ensuring training, validation, and testing datasets are relevant, representative, free of errors, and complete."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Data Governance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#RiskControl"
  } ]
}, {
  "@id" : "https://w3id.org/airco#Database",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A structured repository for storing and retrieving data."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Database"
  } ]
}, {
  "@id" : "https://w3id.org/airco#DecisionPatternDetection",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The capability of an AI system to detect decision-making patterns or deviations from prior decision-making patterns, without replacing or influencing previously completed human assessments."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Decision Pattern Detection Capability"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/airo#AICapability"
  }, {
    "@id" : "_:genid32"
  } ]
}, {
  "@id" : "https://w3id.org/airco#DeepFakeAIDeployer",
