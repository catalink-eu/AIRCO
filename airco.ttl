                                                            ] ;
                                        rdfs:subClassOf airo:AISystem ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :triggersRegulation ;
                                                          owl:someValuesFrom :ProhibitedUseCase_SubliminalManipulativeDeceptive
                                                        ] ;
                                        rdfs:comment "AI system archetype that triggers ProhibitedUseCase_SubliminalManipulativeDeceptive."@en ;
                                        rdfs:label "Subliminal/Manipulative/Deceptive AI System"@en .


###  https://w3id.org/airco#System_SyntheticContentGeneration
:System_SyntheticContentGeneration rdf:type owl:Class ;
                                   owl:equivalentClass [ owl:intersectionOf ( airo:AISystem
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty airo:hasPurpose ;
                                                                                owl:someValuesFrom vair:ContentGeneration
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                   rdfs:subClassOf airo:AISystem ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :triggersRegulation ;
                                                     owl:someValuesFrom :TransparencyRiskUseCase_SyntheticContentGeneration
                                                   ] ;
                                   rdfs:comment "AI system archetype that triggers TransparencyRiskUseCase_SyntheticContentGeneration."@en ;
                                   rdfs:label "Synthetic Content Generation System"@en .


###  https://w3id.org/airco#System_SystemicRiskGPAI
:System_SystemicRiskGPAI rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( airo:AISystem
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :hasTrainingCharacteristic ;
                                                                      owl:someValuesFrom :HighComputeTraining
                                                                    ]
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty airo:hasModel ;
                                                                      owl:someValuesFrom airo:GPAIModel
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf airo:AISystem ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :triggersRegulation ;
                                           owl:someValuesFrom :SystemicRiskGPAIModel
                                         ] ;
                         rdfs:comment "AI system archetype for systems based on a GPAI model that present systemic risks."@en ;
                         rdfs:label "Systemic Risk GPAI System"@en .


###  https://w3id.org/airco#SystemicRiskGPAIModel
:SystemicRiskGPAIModel rdf:type owl:Class ;
                       rdfs:subClassOf airo:GPAIModel ,
                                       [ rdf:type owl:Class ;
                                         owl:unionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasCondition ;
                                                         owl:someValuesFrom :Condition_HighImpactCapabilitiesOverride
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasRiskSource ;
                                                         owl:someValuesFrom :HighImpactCapability
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasTrainingCharacteristic ;
                                                         owl:someValuesFrom :HighComputeTraining
                                                       ]
                                                     )
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasRiskCategory ;
                                         owl:someValuesFrom :GPAIRiskCategory
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty airo:hasStakeholder ;
                                         owl:someValuesFrom :SystemicRiskGPAIProvider
                                       ] ;
                       terms:source "EU AI Act, Article 51"@en ;
                       rdfs:comment "A GPAI model that presents systemic risks. GPAI models present systemic risks when they have high impact capabilities based on technical tools and methodologies, when the cumulative amount of compute used for training is greater than 10^25 FLOPs, or when the Commission determines high impact capabilities."@en ;
                       rdfs:label "Systemic-Risk GPAI Model"@en .


###  https://w3id.org/airco#SystemicRiskGPAIProvider
:SystemicRiskGPAIProvider rdf:type owl:Class ;
                          rdfs:subClassOf :GPAIProvider ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_CopyrightPolicy
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_Cybersecurity
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_DownstreamProviderInfo
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_ModelEvaluation
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_SeriousIncidentReporting
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_SystemicRiskMitigation
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_SystemicRiskNotification
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasObligation ;
                                            owl:someValuesFrom :GPAIObligation_TrainingSummary
                                          ] ;
                          terms:source "EU AI Act, Article 51"@en ;
                          rdfs:comment "A provider of a GPAI model that presents systemic risks. Subject to additional obligations beyond standard GPAI obligations."@en ;
                          rdfs:label "Systemic-Risk GPAI Provider"@en .


###  https://w3id.org/airco#SystemicRiskObligation
:SystemicRiskObligation rdf:type owl:Class ;
                        rdfs:subClassOf :GPAIObligation ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :appliesToStakeholder ;
                                          owl:someValuesFrom :SystemicRiskGPAIProvider
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :isObligationOf ;
                                          owl:someValuesFrom :SystemicRiskGPAIModel
                                        ] ;
                        terms:source "EU AI Act, Article 55"@en ;
                        rdfs:comment "Additional obligations for GPAI models with systemic risk, beyond the standard GPAI obligations."@en ;
                        rdfs:label "Systemic-Risk Obligation"@en .


###  https://w3id.org/airco#TradeUnionMembership
:TradeUnionMembership rdf:type owl:Class ;
                      rdfs:subClassOf :ProhibitedSensitiveAttributes ;
                      rdfs:label "Trade Union Membership"@en .


###  https://w3id.org/airco#TraffickingVictim
:TraffickingVictim rdf:type owl:Class ;
                   rdfs:subClassOf :Victim ;
                   rdfs:comment "A person who has been human trafficked or sexually exploited, and is the subject of a search using real-time remote biometric identification."@en ;
                   rdfs:label "Trafficking Victim"@en .


###  https://w3id.org/airco#TrainingSummary
:TrainingSummary rdf:type owl:Class ;
                 rdfs:subClassOf airo:Documentation ;
                 rdfs:comment "A sufficiently detailed summary about the content used for training a GPAI model."@en ;
                 rdfs:label "Training Summary"@en .


###  https://w3id.org/airco#TransparencyObligation
:TransparencyObligation rdf:type owl:Class ;
                        rdfs:subClassOf :Obligation ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :requiresRiskControl ;
                                          owl:someValuesFrom vair:TransparencyMeasure
                                        ] ;
                        terms:source "EU AI Act, Article 50"@en ;
                        rdfs:comment "A transparency obligation under Article 50 of the EU AI Act."@en ;
                        rdfs:label "Transparency Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_BiometricCategorisationDisclosure
:TransparencyObligation_BiometricCategorisationDisclosure rdf:type owl:Class ;
                                                          rdfs:subClassOf :DisclosureRequirement ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :appliesToStakeholder ;
                                                                            owl:someValuesFrom :BiometricCategorisationAIDeployer
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :appliesToSubject ;
                                                                            owl:someValuesFrom vair:NaturalPerson
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasException ;
                                                                            owl:someValuesFrom :Exception_CriminalLawEnforcement
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty airo:compliesWithRegulation ;
                                                                            owl:hasValue :Directive2016_680
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty airo:compliesWithRegulation ;
                                                                            owl:hasValue :GDPR
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty airo:compliesWithRegulation ;
                                                                            owl:hasValue :Regulation2018_1725
                                                                          ] ;
                                                          terms:source "EU AI Act, Article 50(3)"@en ;
                                                          rdfs:comment "Deployers of biometric categorisation systems must inform affected individuals and comply with applicable EU data protection laws."@en ;
                                                          rdfs:label "Biometric Categorisation Disclosure Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_CodesOfPractice
:TransparencyObligation_CodesOfPractice rdf:type owl:Class ;
                                        rdfs:subClassOf :TransparencyObligation ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :appliesToStakeholder ;
                                                          owl:someValuesFrom :AIOffice
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :governsObligation ;
                                                          owl:someValuesFrom [ rdf:type owl:Class ;
                                                                               owl:unionOf ( :TransparencyObligation_DeepFakeDisclosure
                                                                                             :TransparencyObligation_SyntheticContentGenerationMarking
                                                                                           )
                                                                             ]
                                                        ] ;
                                        terms:source "EU AI Act, Article 50(7)"@en ;
                                        rdfs:comment "The AI Office shall encourage and facilitate drawing up of codes of practice at Union level to facilitate detection and labelling of artificially generated or manipulated content."@en ;
                                        rdfs:label "Codes of Practice for Content Labelling Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_DeepFakeDisclosure
:TransparencyObligation_DeepFakeDisclosure rdf:type owl:Class ;
                                           rdfs:subClassOf :DisclosureRequirement ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :appliesToStakeholder ;
                                                             owl:someValuesFrom :DeepFakeAIDeployer
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :hasException ;
                                                             owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                  owl:unionOf ( :Exception_ArtisticFictionalWork
                                                                                                :Exception_CriminalLawEnforcement
                                                                                              )
                                                                                ]
                                                           ] ;
                                           terms:source "EU AI Act, Article 50(4)"@en ;
                                           rdfs:comment "Deployers of AI systems generating or manipulating image, audio, or video deep fakes must disclose that content has been artificially generated or manipulated."@en ;
                                           rdfs:label "Deep Fake Disclosure Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_EmotionRecognitionDisclosure
:TransparencyObligation_EmotionRecognitionDisclosure rdf:type owl:Class ;
                                                     rdfs:subClassOf :DisclosureRequirement ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :appliesToStakeholder ;
                                                                       owl:someValuesFrom :EmotionRecognitionAIDeployer
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :appliesToSubject ;
                                                                       owl:someValuesFrom vair:NaturalPerson
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :hasException ;
                                                                       owl:someValuesFrom :Exception_CriminalLawEnforcement
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty airo:compliesWithRegulation ;
                                                                       owl:hasValue :Directive2016_680
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty airo:compliesWithRegulation ;
                                                                       owl:hasValue :GDPR
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty airo:compliesWithRegulation ;
                                                                       owl:hasValue :Regulation2018_1725
                                                                     ] ;
                                                     terms:source "EU AI Act, Article 50(3)"@en ;
                                                     rdfs:comment "Deployers of emotion recognition systems must inform affected individuals and comply with applicable EU data protection laws."@en ;
                                                     rdfs:label "Emotion Recognition Disclosure Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_InteractingWithPeopleNotification
:TransparencyObligation_InteractingWithPeopleNotification rdf:type owl:Class ;
                                                          rdfs:subClassOf :NotificationRequirement ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :appliesToStakeholder ;
                                                                            owl:someValuesFrom :InteractingWithPeopleAIProvider
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :appliesToSubject ;
                                                                            owl:someValuesFrom vair:NaturalPerson
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasCondition ;
                                                                            owl:someValuesFrom :Condition_NotObviousAI
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasException ;
                                                                            owl:someValuesFrom :Exception_CriminalLawEnforcement
                                                                          ] ;
                                                          terms:source "EU AI Act, Article 50(1)"@en ;
                                                          rdfs:comment "Providers must ensure that individuals are informed when they are interacting with an AI system, unless this is obvious in the given context."@en ;
                                                          rdfs:label "AI Interacting with People Notification Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_PublicInterestTextGenerationDisclosure
:TransparencyObligation_PublicInterestTextGenerationDisclosure rdf:type owl:Class ;
                                                               rdfs:subClassOf :DisclosureRequirement ,
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty :appliesToStakeholder ;
                                                                                 owl:someValuesFrom :PublicInterestTextGenerationAIDeployer
                                                                               ] ,
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty :hasException ;
                                                                                 owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                      owl:unionOf ( :Exception_CriminalLawEnforcement
                                                                                                                    :Exception_HumanEditorialReview
                                                                                                                  )
                                                                                                    ]
                                                                               ] ;
                                                               terms:source "EU AI Act, Article 50(4)"@en ;
                                                               rdfs:comment "Deployers of AI systems generating or manipulating text published with the purpose of informing the public on matters of public interest must disclose that the text has been artificially generated or manipulated."@en ;
                                                               rdfs:label "Public Interest AI Text Generation Disclosure Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_SyntheticContentGenerationMarking
:TransparencyObligation_SyntheticContentGenerationMarking rdf:type owl:Class ;
                                                          rdfs:subClassOf :MarkingRequirement ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :appliesToStakeholder ;
                                                                            owl:someValuesFrom :SyntheticContentGenerationAIProvider
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasCondition ;
                                                                            owl:someValuesFrom :Condition_TechnicalFeasibility
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasException ;
                                                                            owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                 owl:unionOf ( :Exception_AssistiveEditing
                                                                                                               :Exception_CriminalLawEnforcement
                                                                                                               :Exception_NoSubstantialAlteration
                                                                                                             )
                                                                                               ]
                                                                          ] ;
                                                          terms:source "EU AI Act, Article 50(2)"@en ;
                                                          rdfs:comment "Providers of AI systems generating synthetic audio, image, video, or text content must ensure outputs are marked in machine-readable format and detectable as artificially generated or manipulated."@en ;
                                                          rdfs:label "Machine-Readable Synthetic Content Marking Obligation"@en .


###  https://w3id.org/airco#TransparencyObligation_TimelinessAccessibility
:TransparencyObligation_TimelinessAccessibility rdf:type owl:Class ;
                                                rdfs:subClassOf :TransparencyObligation ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :governsObligation ;
                                                                  owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                       owl:unionOf ( :TransparencyObligation_DeepFakeDisclosure
                                                                                                     :TransparencyObligation_EmotionRecognitionDisclosure
                                                                                                     :TransparencyObligation_InteractingWithPeopleNotification
                                                                                                     :TransparencyObligation_PublicInterestTextGenerationDisclosure
                                                                                                     :TransparencyObligation_SyntheticContentGenerationMarking
                                                                                                   )
                                                                                     ]
                                                                ] ;
                                                terms:source "EU AI Act, Article 50(5)"@en ;
                                                rdfs:comment "Information under Article 50(1)-(4) must be provided in a clear and distinguishable manner at the latest at the time of the first interaction or exposure, and must conform to applicable accessibility requirements."@en ;
                                                rdfs:label "Timeliness and Accessibility of Transparency Information Obligation"@en .


###  https://w3id.org/airco#TransparencyRiskAIDeployer
:TransparencyRiskAIDeployer rdf:type owl:Class ;
                            rdfs:subClassOf airo:AIDeployer ;
                            rdfs:comment "Deployer of an AI System with transparency obligations."@en ;
                            rdfs:label "Transparency-Risk AI Deployer"@en .


###  https://w3id.org/airco#TransparencyRiskAIProvider
:TransparencyRiskAIProvider rdf:type owl:Class ;
                            rdfs:subClassOf airo:AIProvider ;
                            rdfs:comment "Provider of an AI System with transparency obligations."@en ;
                            rdfs:label "Transparency-Risk AI Provider"@en .


###  https://w3id.org/airco#TransparencyRiskCategory
:TransparencyRiskCategory rdf:type owl:Class ;
                          rdfs:subClassOf :RiskCategory ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :triggeredByRegulation ;
                                            owl:someValuesFrom [ rdf:type owl:Class ;
                                                                 owl:unionOf ( :DisclosureRequirement
                                                                               :MarkingRequirement
                                                                               :NotificationRequirement
                                                                             )
                                                               ]
                                          ] ;
                          terms:source "EU AI Act, Chapter IV, Article 50"@en ;
                          rdfs:comment "The Transparency-Risk category in the AI Act relating to transparency obligations in AI systems."@en ;
                          rdfs:label "Transparency-Risk Category"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase
:TransparencyRiskUseCase rdf:type owl:Class ;
                         rdfs:subClassOf :UseCase ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :appliesToStakeholder ;
                                           owl:someValuesFrom [ rdf:type owl:Class ;
                                                                owl:unionOf ( :TransparencyRiskAIDeployer
                                                                              :TransparencyRiskAIProvider
                                                                            )
                                                              ]
                                         ] ;
                         rdfs:comment "Transparency-Risk AI practice requiring transparency measures."@en ;
                         rdfs:label "Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase_BiometricCategorisation
:TransparencyRiskUseCase_BiometricCategorisation rdf:type owl:Class ;
                                                 rdfs:subClassOf :TransparencyRiskUseCase ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :appliesToCapability ;
                                                                   owl:someValuesFrom vair:BiometricCategorisation
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :appliesToStakeholder ;
                                                                   owl:someValuesFrom :BiometricCategorisationAIDeployer
                                                                 ] ;
                                                 terms:source "EU AI Act, Article 50(3)"@en ;
                                                 rdfs:comment "Biometric-categorisation systems."@en ;
                                                 rdfs:label "Biometric Categorisation Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase_DeepFakeGeneration
:TransparencyRiskUseCase_DeepFakeGeneration rdf:type owl:Class ;
                                            rdfs:subClassOf :TransparencyRiskUseCase ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :appliesToPurpose ;
                                                              owl:someValuesFrom :DeepFakeGeneration
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :appliesToStakeholder ;
                                                              owl:someValuesFrom :DeepFakeAIDeployer
                                                            ] ;
                                            terms:source "EU AI Act, Article 50(4)"@en ;
                                            rdfs:comment "Generating or manipulating image, audio, or video deep fakes."@en ;
                                            rdfs:label "Deep Fake Generation Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase_EmotionRecognition
:TransparencyRiskUseCase_EmotionRecognition rdf:type owl:Class ;
                                            rdfs:subClassOf :TransparencyRiskUseCase ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :appliesToCapability ;
                                                              owl:someValuesFrom vair:EmotionRecognition
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :appliesToStakeholder ;
                                                              owl:someValuesFrom :EmotionRecognitionAIDeployer
                                                            ] ;
                                            terms:source "EU AI Act, Article 50(3)"@en ;
                                            rdfs:comment "Emotion-recognition systems."@en ;
                                            rdfs:label "Emotion Recognition Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase_InteractingWithPeople
:TransparencyRiskUseCase_InteractingWithPeople rdf:type owl:Class ;
                                               rdfs:subClassOf :TransparencyRiskUseCase ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :appliesToStakeholder ;
                                                                 owl:someValuesFrom :InteractingWithPeopleAIProvider
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :appliesToSubject ;
                                                                 owl:someValuesFrom vair:NaturalPerson
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :hasSubjectInvolvement ;
                                                                 owl:someValuesFrom vair:ActiveInvolvement
                                                               ] ;
                                               terms:source "EU AI Act, Article 50(1)"@en ;
                                               rdfs:comment "AI directly interacting with people."@en ;
                                               rdfs:label "AI Interacting with People Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase_PublicInterestTextGeneration
:TransparencyRiskUseCase_PublicInterestTextGeneration rdf:type owl:Class ;
                                                      rdfs:subClassOf :TransparencyRiskUseCase ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :appliesToContentType ;
                                                                        owl:someValuesFrom :SyntheticTextContent
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :appliesToPurpose ;
                                                                        owl:someValuesFrom :PublicInterestTextGeneration
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :appliesToStakeholder ;
                                                                        owl:someValuesFrom :PublicInterestTextGenerationAIDeployer
                                                                      ] ;
                                                      terms:source "EU AI Act, Article 50(4)"@en ;
                                                      rdfs:comment "Generating or manipulating text published with the purpose of informing the public on matters of public interest."@en ;
                                                      rdfs:label "Public Interest Text AI Generation Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#TransparencyRiskUseCase_SyntheticContentGeneration
:TransparencyRiskUseCase_SyntheticContentGeneration rdf:type owl:Class ;
                                                    rdfs:subClassOf :TransparencyRiskUseCase ,
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :appliesToPurpose ;
                                                                      owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                           owl:unionOf ( :GeneratingTextContent
                                                                                                         vair:GeneratingAudioContent
                                                                                                         vair:GeneratingImageContent
                                                                                                         vair:GeneratingVideoContent
                                                                                                       )
                                                                                         ]
                                                                    ] ,
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :appliesToStakeholder ;
                                                                      owl:someValuesFrom :SyntheticContentGenerationAIProvider
                                                                    ] ;
                                                    terms:source "EU AI Act, Article 50(2)"@en ;
                                                    rdfs:comment "Generating synthetic audio, image, video, or text content."@en ;
                                                    rdfs:label "Synthetic Content Generation Transparency-Risk Use Case"@en .


###  https://w3id.org/airco#UrgentPatientTriage
:UrgentPatientTriage rdf:type owl:Class ;
                     rdfs:subClassOf vair:EmergencyTriage ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :appliesToDomain ;
                                       owl:someValuesFrom vair:Health
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :appliesToStakeholder ;
                                       owl:someValuesFrom vair:EmergencyHealthCareProvider
                                     ] ;
                     rdfs:comment "Urgent patient triage in emergency healthcare, classified as high risk under emergency call evaluation."@en ;
                     rdfs:label "Urgent Patient Triage"@en .


###  https://w3id.org/airco#UseCase
:UseCase rdf:type owl:Class ;
         rdfs:comment "A specific use case of an AI system under the EU AI Act. Use cases are classified into risk categories based on applicable classification rules."@en ;
         rdfs:label "Use Case"@en .


###  https://w3id.org/airco#Victim
:Victim rdf:type owl:Class ;
        rdfs:subClassOf airo:AISubject ;
        rdfs:comment "A person who has suffered harm from, or is the target of, a criminal offence or other wrongful act."@en ;
        rdfs:label "Victim"@en .


