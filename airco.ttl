@prefix : <https://w3id.org/airco#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix airo: <https://w3id.org/airo#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vair: <https://w3id.org/vair#> .
@prefix terms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/airco> .

<https://w3id.org/airco> rdf:type owl:Ontology ;
                          owl:imports <https://w3id.org/airo> ,
                                      <https://w3id.org/vair> ;
                          terms:description "Encodes EU AI Act risk categories, obligations, exceptions, and transparency requirements. Aligned with AIRO and VAIR ontologies."@en ;
                          terms:source "EU AI Act"@en ;
                          terms:title "AI Risk Compliance Ontology"@en ;
                          rdfs:label "AI Risk Compliance Ontology"@en .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/airco#affectsArea
:affectsArea rdf:type owl:ObjectProperty ;
             rdfs:range airo:AreaOfImpact ;
             rdfs:comment "Links an entity to the impact area it affects."@en ;
             rdfs:label "affects area"@en .


###  https://w3id.org/airco#appliesToCapability
:appliesToCapability rdf:type owl:ObjectProperty ;
                     rdfs:range airo:AICapability ;
                     rdfs:comment "Links an entity to the AI capability it concerns."@en ;
                     rdfs:label "applies to capability"@en .


###  https://w3id.org/airco#appliesToContentType
:appliesToContentType rdf:type owl:ObjectProperty ;
                      rdfs:range vair:Content ;
                      rdfs:comment "Links an entity to the content type it covers."@en ;
                      rdfs:label "applies to content type"@en .


###  https://w3id.org/airco#appliesToDomain
:appliesToDomain rdf:type owl:ObjectProperty ;
                 rdfs:range airo:Domain ;
                 rdfs:comment "Links an entity to the domain in which it applies."@en ;
                 rdfs:label "applies to domain"@en .


###  https://w3id.org/airco#appliesToInput
:appliesToInput rdf:type owl:ObjectProperty ;
                rdfs:range airo:Input ;
                rdfs:comment "Links an entity to the type of input data it concerns."@en ;
                rdfs:label "applies to input"@en .


###  https://w3id.org/airco#appliesToLocality
:appliesToLocality rdf:type owl:ObjectProperty ;
                   rdfs:range airo:LocalityOfUse ;
                   rdfs:comment "Links an entity to the locality of use it concerns."@en ;
                   rdfs:label "applies to locality"@en .


###  https://w3id.org/airco#appliesToPurpose
:appliesToPurpose rdf:type owl:ObjectProperty ;
                  rdfs:range airo:Purpose ;
                  rdfs:comment "Links an entity to the purpose it concerns."@en ;
                  rdfs:label "applies to purpose"@en .


###  https://w3id.org/airco#appliesToStakeholder
:appliesToStakeholder rdf:type owl:ObjectProperty ;
                      rdfs:range airo:Stakeholder ;
                      rdfs:comment "Links an entity to the stakeholder role responsible."@en ;
                      rdfs:label "applies to stakeholder"@en .


###  https://w3id.org/airco#appliesToSubject
:appliesToSubject rdf:type owl:ObjectProperty ;
                  rdfs:range airo:AISubject ;
                  rdfs:comment "Links an entity to the type of AI subject it affects."@en ;
                  rdfs:label "applies to subject"@en .


###  https://w3id.org/airco#appliesToSystem
:appliesToSystem rdf:type owl:ObjectProperty ;
                 rdfs:range [ rdf:type owl:Class ;
                              owl:unionOf ( airo:AIModel
                                            airo:AISystem
                                          )
                            ] ;
                 rdfs:comment "Links an entity to the AI system it applies to."@en ;
                 rdfs:label "applies to system"@en .


###  https://w3id.org/airco#appliesToTechnique
:appliesToTechnique rdf:type owl:ObjectProperty ;
                    rdfs:range airo:Technique ;
                    rdfs:comment "Links an entity to the AI technique it concerns."@en ;
                    rdfs:label "applies to technique"@en .


###  https://w3id.org/airco#causesConsequence
:causesConsequence rdf:type owl:ObjectProperty ;
                   rdfs:range airo:Consequence ;
                   rdfs:comment "Links an entity to the consequence it causes."@en ;
                   rdfs:label "causes consequence"@en .


###  https://w3id.org/airco#causesImpact
:causesImpact rdf:type owl:ObjectProperty ;
              rdfs:range airo:Impact ;
              rdfs:comment "Links an entity to the impact it causes."@en ;
              rdfs:label "causes impact"@en .


###  https://w3id.org/airco#exploitsVulnerabilityType
:exploitsVulnerabilityType rdf:type owl:ObjectProperty ;
                           rdfs:range airo:Vulnerability ;
                           rdfs:comment "Links an entity to the specific vulnerability type exploited."@en ;
                           rdfs:label "exploits vulnerability type"@en .


###  https://w3id.org/airco#governsObligation
:governsObligation rdf:type owl:ObjectProperty ;
                   rdfs:domain :Obligation ;
                   rdfs:range :Obligation ;
                   rdfs:comment "Links one obligation to another obligation whose implementation it governs or qualifies."@en ;
                   rdfs:label "governs obligation"@en .


###  https://w3id.org/airco#hasCondition
:hasCondition rdf:type owl:ObjectProperty ;
              rdfs:range :Condition ;
              rdfs:comment "Links an entity to a condition under which it applies."@en ;
              rdfs:label "has condition"@en .


###  https://w3id.org/airco#hasDataSource
:hasDataSource rdf:type owl:ObjectProperty ;
               rdfs:range <https://w3id.org/dpv#Data> ;
               rdfs:comment "Links an entity to the data source type involved."@en ;
               rdfs:label "has data source"@en .


###  https://w3id.org/airco#hasException
:hasException rdf:type owl:ObjectProperty ;
              rdfs:range :Exception ;
              rdfs:comment "Links an entity to a exception under which it won't apply."@en ;
              rdfs:label "has exception"@en .


###  https://w3id.org/airco#hasObligation
:hasObligation rdf:type owl:ObjectProperty ;
               rdfs:range :Obligation ;
               rdfs:comment "Links an entity to an obligation it must fulfil."@en ;
               rdfs:label "has obligation"@en .


###  https://w3id.org/airco#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ;
                 rdfs:range :RiskCategory ;
                 rdfs:comment "Links an entity to a risk category."@en ;
                 rdfs:label "has risk category"@en .


###  https://w3id.org/airco#hasRiskSource
:hasRiskSource rdf:type owl:ObjectProperty ;
               rdfs:range airo:RiskSource ;
               rdfs:comment "Links an entity to a risk source."@en ;
               rdfs:label "has risk source"@en .


###  https://w3id.org/airco#hasSubjectInvolvement
:hasSubjectInvolvement rdf:type owl:ObjectProperty ;
                       rdfs:range airo:HumanInvolvement ;
                       rdfs:comment "Links an entity to the involvement level of its subject."@en ;
                       rdfs:label "has subject involvement type"@en .


###  https://w3id.org/airco#hasTrainingCharacteristic
:hasTrainingCharacteristic rdf:type owl:ObjectProperty ;
                           rdfs:domain [ rdf:type owl:Class ;
                                         owl:unionOf ( airo:AIModel
                                                       airo:AISystem
                                                     )
                                       ] ;
                           rdfs:comment "Links an AI system to a characteristic of its training process."@en ;
                           rdfs:label "has training characteristic"@en .


###  https://w3id.org/airco#includesCrimeType
:includesCrimeType rdf:type owl:ObjectProperty ;
                   rdfs:range :SeriousCrime ;
                   rdfs:comment "Links an entity to a type of serious crime it encompasses."@en ;
                   rdfs:label "includes crime type"@en .


###  https://w3id.org/airco#infersSensitiveAttribute
:infersSensitiveAttribute rdf:type owl:ObjectProperty ;
                          rdfs:range :SensitiveAttribute ;
                          rdfs:comment "Links an entity to the sensitive attribute it infers."@en ;
                          rdfs:label "infers sensitive attribute"@en .


###  https://w3id.org/airco#isExceptionTo
:isExceptionTo rdf:type owl:ObjectProperty ;
               rdfs:domain :Exception ;
               rdfs:comment "Links an exception to the rule it modifies."@en ;
               rdfs:label "is exception to"@en .


###  https://w3id.org/airco#isObligationOf
:isObligationOf rdf:type owl:ObjectProperty ;
                rdfs:domain :Obligation ;
                rdfs:comment "Links an obligation to the entity it burdens."@en ;
                rdfs:label "is obligation of"@en .


###  https://w3id.org/airco#registersIn
:registersIn rdf:type owl:ObjectProperty ;
             rdfs:range :Database ;
             rdfs:comment "Links an entity to a database in which registration is required or specified."@en ;
             rdfs:label "registers in"@en .


###  https://w3id.org/airco#requiresAuthorisation
:requiresAuthorisation rdf:type owl:ObjectProperty ;
                       rdfs:range :AuthorisationBody ;
                       rdfs:comment "Links an entity to the authorisation body that must approve it."@en ;
                       rdfs:label "requires authorisation"@en .


###  https://w3id.org/airco#requiresDocumentation
:requiresDocumentation rdf:type owl:ObjectProperty ;
                       rdfs:range airo:Documentation ;
                       rdfs:comment "Links an entity to the documentation it requires."@en ;
                       rdfs:label "requires documentation"@en .


###  https://w3id.org/airco#requiresRiskControl
:requiresRiskControl rdf:type owl:ObjectProperty ;
                     rdfs:range airo:RiskControl ;
                     rdfs:comment "Links an entity to a risk control measure it mandates."@en ;
                     rdfs:label "requires risk control"@en .


###  https://w3id.org/airco#triggeredByRegulation
:triggeredByRegulation rdf:type owl:ObjectProperty ;
                       rdfs:domain :RiskCategory ;
                       rdfs:comment "Links an AI risk category to the regulation that triggers its risk classification."@en ;
                       rdfs:label "triggered by regulation"@en .


###  https://w3id.org/airco#triggersRegulation
:triggersRegulation rdf:type owl:ObjectProperty ;
                    rdfs:domain airo:AISystem ;
                    rdfs:comment "Links an AI system archetype to the regulatory class (prohibition, use case, transparency obligation, or risk category) it triggers when a system matches its detection criteria."@en ;
                    rdfs:label "triggers regulation"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/airco#hasComputeThreshold
:hasComputeThreshold rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Compute threshold value for classification."@en ;
                     rdfs:label "has compute threshold"@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/airco#AIOffice
:AIOffice rdf:type owl:Class ;
          rdfs:subClassOf airo:Stakeholder ;
          rdfs:comment "The EU AI Office."@en ;
          rdfs:label "AI Office"@en .


###  https://w3id.org/airco#AbductionVictim
:AbductionVictim rdf:type owl:Class ;
                 rdfs:subClassOf :Victim ;
                 rdfs:comment "A victim of abduction who is the subject of a search using real-time remote biometric identification."@en ;
                 rdfs:label "Abduction Victim"@en .


###  https://w3id.org/airco#AgeVulnerability
:AgeVulnerability rdf:type owl:Class ;
                  rdfs:subClassOf airo:Vulnerability ;
                  rdfs:label "Age Vulnerability"@en .


###  https://w3id.org/airco#AlternativeDisputeResolution
:AlternativeDisputeResolution rdf:type owl:Class ;
                              rdfs:subClassOf vair:SettlingDispute ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :appliesToDomain ;
                                                owl:someValuesFrom vair:AdministrationOfJustice
                                              ] ;
                              rdfs:comment "Use of AI in alternative dispute resolution, classified as high risk under the administration of justice."@en ;
                              rdfs:label "Alternative Dispute Resolution"@en .


###  https://w3id.org/airco#ArmedRobbery
:ArmedRobbery rdf:type owl:Class ;
              rdfs:subClassOf :SeriousCrime ;
              rdfs:label "Armed Robbery"@en .


###  https://w3id.org/airco#AuthorisationBody
:AuthorisationBody rdf:type owl:Class ;
                   rdfs:subClassOf airo:Stakeholder ;
                   rdfs:comment "A body that can authorise certain AI practices."@en ;
                   rdfs:label "Authorisation Body"@en .


###  https://w3id.org/airco#BiometricCategorisationAIDeployer
:BiometricCategorisationAIDeployer rdf:type owl:Class ;
                                   rdfs:subClassOf :TransparencyRiskAIDeployer ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasObligation ;
                                                     owl:someValuesFrom :TransparencyObligation_BiometricCategorisationDisclosure
                                                   ] ;
                                   terms:source "EU AI Act, Article 50(3)"@en ;
                                   rdfs:comment "A deployer of a biometric-categorisation system, subject to transparency obligations."@en ;
                                   rdfs:label "Biometric Categorisation AI Deployer"@en .


###  https://w3id.org/airco#BiometricData
:BiometricData rdf:type owl:Class ;
               rdfs:subClassOf airo:Input ;
               rdfs:comment "Biometric data used as input to an AI system."@en ;
               rdfs:label "Biometric Data"@en .


###  https://w3id.org/airco#CCTVFootage
:CCTVFootage rdf:type owl:Class ;
             rdfs:subClassOf <https://w3id.org/dpv#SensitiveData> ;
             rdfs:comment "CCTV footage used as a data source."@en ;
             rdfs:label "CCTV Footage"@en .


###  https://w3id.org/airco#Condition
:Condition rdf:type owl:Class ;
           rdfs:comment "A condition that must be satisfied for a rule or exception to apply."@en ;
           rdfs:label "Condition"@en .


###  https://w3id.org/airco#Condition_CodesOfPracticeParticipation
:Condition_CodesOfPracticeParticipation rdf:type owl:Class ;
                                        rdfs:subClassOf :Condition ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :appliesToStakeholder ;
                                                          owl:someValuesFrom :AIOffice
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :appliesToStakeholder ;
                                                          owl:someValuesFrom [ rdf:type owl:Class ;
                                                                               owl:unionOf ( :DownstreamProvider
                                                                                             :NationalCompetentAuthority
                                                                                             :ScientificPanelOfExperts
                                                                                           )
                                                                             ]
                                                        ] ;
                                        terms:source "EU AI Act, Article 56(4)"@en ;
                                        rdfs:comment "AI Office may invite GPAI model providers, relevant national competent authorities to participate, while civil society, industry, academia, downstream providers, and independent experts may support the process."@en ;
                                        rdfs:label "Codes of Practice Participation Condition"@en .


###  https://w3id.org/airco#Condition_CodesOfPracticeScope
:Condition_CodesOfPracticeScope rdf:type owl:Class ;
                                rdfs:subClassOf :Condition ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :requiresDocumentation ;
                                                  owl:someValuesFrom vair:TechnicalDocumentation
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty airo:followsCodeOfConduct ;
                                                  owl:someValuesFrom airo:CodeOfConduct
                                                ] ;
                                terms:source "EU AI Act, Article 56(3)"@en ;
                                rdfs:comment "Codes will cover but not necessarily be limited to: information in technical documentation for authorities and downstream providers, identification of type and nature of systemic risks and their sources, and modalities of risk management."@en ;
                                rdfs:label "Codes of Practice Scope Condition"@en .


###  https://w3id.org/airco#Condition_EditorialResponsibility
:Condition_EditorialResponsibility rdf:type owl:Class ;
                                   rdfs:subClassOf :Condition ;
                                   terms:source "EU AI Act, Article 50(4)"@en ;
                                   rdfs:comment "A natural or legal person must hold editorial responsibility for the publication."@en ;
                                   rdfs:label "Editorial Responsibility Condition"@en .


###  https://w3id.org/airco#Condition_HighImpactCapabilitiesOverride
:Condition_HighImpactCapabilitiesOverride rdf:type owl:Class ;
                                          rdfs:subClassOf :Condition ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :appliesToStakeholder ;
                                                            owl:someValuesFrom :ScientificPanelOfExperts
                                                          ] ;
                                          terms:source "EU AI Act, Article 51(1)"@en ;
                                          rdfs:comment "The Commission may decide, on its own or via qualified alert from the scientific panel of independent experts, that a model has high impact capabilities, rendering it systemic."@en ;
                                          rdfs:label "High Impact Capabilities Condition"@en .


###  https://w3id.org/airco#Condition_HumanAssessmentAugmentation
:Condition_HumanAssessmentAugmentation rdf:type owl:Class ;
                                       rdfs:subClassOf :Condition ;
                                       terms:source "EU AI Act, Article 5(1)(e)"@en ;
                                       rdfs:comment "AI must augment rather than replace human assessments."@en ;
                                       rdfs:label "Human Assessment Augmentation Condition"@en .


###  https://w3id.org/airco#Condition_LawfullyAcquiredDataset
:Condition_LawfullyAcquiredDataset rdf:type owl:Class ;
                                   rdfs:subClassOf :Condition ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasDataSource ;
                                                     owl:someValuesFrom :LawfullyAcquiredBiometricDataset
                                                   ] ;
                                   terms:source "EU AI Act, Article 5(1)(c)"@en ;
                                   rdfs:comment "The biometric dataset must have been lawfully acquired."@en ;
                                   rdfs:label "Lawfully Acquired Dataset Condition"@en .


###  https://w3id.org/airco#Condition_MeaningfulHumanReview
:Condition_MeaningfulHumanReview rdf:type owl:Class ;
                                 rdfs:subClassOf :Condition ;
                                 terms:source "EU AI Act, Article 50(4)"@en ;
                                 rdfs:comment "The AI-generated content must have undergone meaningful human editorial review."@en ;
                                 rdfs:label "Meaningful Human Review Condition"@en .


###  https://w3id.org/airco#Condition_NonHamperingDisclosure
:Condition_NonHamperingDisclosure rdf:type owl:Class ;
                                  rdfs:subClassOf :Condition ;
                                  terms:source "EU AI Act, Article 50(4)"@en ;
                                  rdfs:comment "Disclosure must not hamper the display or enjoyment of the work."@en ;
                                  rdfs:label "Non-Hampering Disclosure Condition"@en .


###  https://w3id.org/airco#Condition_NotObviousAI
:Condition_NotObviousAI rdf:type owl:Class ;
                        rdfs:subClassOf :Condition ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasSubjectInvolvement ;
                                          owl:someValuesFrom vair:InformedInvolvement
                                        ] ;
                        terms:source "EU AI Act, Article 50(1)"@en ;
                        rdfs:comment "Applies unless it is obvious from the point of view of a reasonably well-informed, observant, and circumspect natural person."@en ;
                        rdfs:label "Not Obviously AI Condition"@en .


###  https://w3id.org/airco#Condition_NotReplacingHumanAssessment
:Condition_NotReplacingHumanAssessment rdf:type owl:Class ;
                                       rdfs:subClassOf :Condition ;
                                       terms:source "EU AI Act, Article 6(3)"@en ;
                                       rdfs:comment "The AI system must not be meant to replace or influence the previously completed human assessment without proper human review."@en ;
                                       rdfs:label "Not Replacing Human Assessment Condition"@en .


###  https://w3id.org/airco#Condition_NotSystemic
:Condition_NotSystemic rdf:type owl:Class ;
                       rdfs:subClassOf :Condition ,
                                       [ rdf:type owl:Class ;
                                         owl:complementOf [ rdf:type owl:Restriction ;
                                                            owl:onProperty :appliesToSystem ;
                                                            owl:someValuesFrom :SystemicRiskGPAIModel
                                                          ]
                                       ] ;
                       terms:source "EU AI Act, Article 53(2)"@en ;
                       rdfs:comment "System must not present systemic risks."@en ;
                       rdfs:label "Not Systemic Condition"@en .


###  https://w3id.org/airco#Condition_ObjectiveVerifiableFacts
:Condition_ObjectiveVerifiableFacts rdf:type owl:Class ;
                                    rdfs:subClassOf :Condition ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :appliesToInput ;
                                                      owl:someValuesFrom :ObjectiveVerifiableFact
                                                    ] ;
                                    terms:source "EU AI Act, Article 5(1)(e)"@en ;
                                    rdfs:comment "Must be based on objective, verifiable facts directly linked to criminal activity."@en ;
                                    rdfs:label "Objective Verifiable Facts Condition"@en .


###  https://w3id.org/airco#Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms
:Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms rdf:type owl:Class ;
                                                                     rdfs:subClassOf :Condition ;
                                                                     terms:source "EU AI Act, Article 5(2)"@en ;
                                                                     rdfs:comment "Using AI-enabled real-time remote biometric identification must account for affected persons' rights and freedoms."@en ;
                                                                     rdfs:label "Account for Rights and Freedoms Condition"@en .


###  https://w3id.org/airco#Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool
:Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool rdf:type owl:Class ;
                                                                     rdfs:subClassOf :Condition ;
                                                                     terms:source "EU AI Act, Article 5(2)"@en ;
                                                                     rdfs:comment "Real-time remote biometric identification is only allowed when not using the tool would cause considerable harm."@en ;
                                                                     rdfs:label "Considerable Harm Without Tool Condition"@en .


###  https://w3id.org/airco#Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment
:Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment rdf:type owl:Class ;
                                                                           rdfs:subClassOf :PreDeploymentCondition ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty :requiresDocumentation ;
                                                                                             owl:someValuesFrom :FundamentalRightsImpactAssessment
                                                                                           ] ;
                                                                           terms:source "EU AI Act, Article 5(3)"@en ;
                                                                           rdfs:comment "Police must complete a fundamental rights impact assessment before deployment of remote biometric identification."@en ;
                                                                           rdfs:label "Fundamental Rights Impact Assessment Condition"@en .


###  https://w3id.org/airco#Condition_RemoteBiometricIdentification_ObtainAuthorisation
:Condition_RemoteBiometricIdentification_ObtainAuthorisation rdf:type owl:Class ;
                                                             rdfs:subClassOf :PreDeploymentCondition ,
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty :hasException ;
                                                                               owl:someValuesFrom :Exception_RemoteBiometricIdentification_UrgencyAuthorisation
                                                                             ] ,
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty :requiresAuthorisation ;
                                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                    owl:unionOf ( :IndependentAdministrativeAuthority
                                                                                                                  vair:JudicialAuthority
                                                                                                                )
                                                                                                  ]
                                                                             ] ;
                                                             terms:source "EU AI Act, Article 5(4)"@en ;
                                                             rdfs:comment "Must obtain authorisation from a judicial authority or independent administrative authority before deployment of remote biometric identification."@en ;
                                                             rdfs:label "Obtain Authorisation Condition"@en .


###  https://w3id.org/airco#Condition_RemoteBiometricIdentification_RegisterInEUDatabase
:Condition_RemoteBiometricIdentification_RegisterInEUDatabase rdf:type owl:Class ;
                                                              rdfs:subClassOf :PreDeploymentCondition ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasException ;
                                                                                owl:someValuesFrom :Exception_RemoteBiometricIdentification_UrgencyRegistration
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :registersIn ;
                                                                                owl:someValuesFrom :EUDatabase
                                                                              ] ;
                                                              terms:source "EU AI Act, Article 5(3)"@en ;
                                                              rdfs:comment "The system must be registered in the EU database before deployment of remote biometric identification."@en ;
                                                              rdfs:label "Register in EU Database Condition"@en .


###  https://w3id.org/airco#Condition_SafetyComponentOrProduct
:Condition_SafetyComponentOrProduct rdf:type owl:Class ;
                                    rdfs:subClassOf :Condition ;
                                    terms:source "EU AI Act, Article 6(1)"@en ;
                                    rdfs:comment "The AI system must be used as a safety component or be a product covered by EU laws in Annex I."@en ;
                                    rdfs:label "Safety Component or Product Condition"@en .


###  https://w3id.org/airco#Condition_SolelyBasedOnProfiling
:Condition_SolelyBasedOnProfiling rdf:type owl:Class ;
                                  rdfs:subClassOf :Condition ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :appliesToCapability ;
                                                    owl:allValuesFrom vair:Profiling
                                                  ] ;
                                  terms:source "EU AI Act, Article 5(1)(e), Annex III, 6(d)"@en ;
                                  rdfs:comment "The assessment must be solely based on profiling or personality traits, without other evidence."@en ;
                                  rdfs:label "Solely Based on Profiling Condition"@en .


###  https://w3id.org/airco#Condition_TechnicalFeasibility
:Condition_TechnicalFeasibility rdf:type owl:Class ;
                                rdfs:subClassOf :Condition ;
                                terms:source "EU AI Act, Article 50(2)"@en ;
                                rdfs:comment "Solutions must be effective, interoperable, robust, and reliable as far as technically feasible."@en ;
                                rdfs:label "Technical Feasibility Condition"@en .


###  https://w3id.org/airco#Condition_ThirdPartyConformityAssessment
:Condition_ThirdPartyConformityAssessment rdf:type owl:Class ;
                                          rdfs:subClassOf :Condition ;
                                          terms:source "EU AI Act, Article 6(1)"@en ;
                                          rdfs:comment "Must be required to undergo a third-party conformity assessment under Annex I laws."@en ;
                                          rdfs:label "Third-Party Conformity Assessment Condition"@en .


###  https://w3id.org/airco#CopyrightPolicy
:CopyrightPolicy rdf:type owl:Class ;
                 rdfs:subClassOf airo:Documentation ;
                 rdfs:comment "A policy established to respect the Copyright Directive."@en ;
                 rdfs:label "Copyright Policy"@en .


###  https://w3id.org/airco#CybersecurityProtection
:CybersecurityProtection rdf:type owl:Class ;
                         rdfs:subClassOf vair:SecurityMeasure ;
                         rdfs:comment "An adequate level of cybersecurity protection."@en ;
                         rdfs:label "Cybersecurity Protection"@en .


###  https://w3id.org/airco#DataGovernance
:DataGovernance rdf:type owl:Class ;
                rdfs:subClassOf airo:RiskControl ;
                rdfs:comment "Data governance measures ensuring training, validation, and testing datasets are relevant, representative, free of errors, and complete."@en ;
                rdfs:label "Data Governance"@en .


###  https://w3id.org/airco#Database
:Database rdf:type owl:Class ;
          rdfs:comment "A structured repository for storing and retrieving data."@en ;
          rdfs:label "Database"@en .


###  https://w3id.org/airco#DecisionPatternDetection
:DecisionPatternDetection rdf:type owl:Class ;
                          rdfs:subClassOf airo:AICapability ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :appliesToCapability ;
                                            owl:someValuesFrom :PatternRecognition
                                          ] ;
                          rdfs:comment "The capability of an AI system to detect decision-making patterns or deviations from prior decision-making patterns, without replacing or influencing previously completed human assessments."@en ;
                          rdfs:label "Decision Pattern Detection Capability"@en .


###  https://w3id.org/airco#DeepFakeAIDeployer
:DeepFakeAIDeployer rdf:type owl:Class ;
                    rdfs:subClassOf :TransparencyRiskAIDeployer ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :TransparencyObligation_DeepFakeDisclosure
                                    ] ;
                    terms:source "EU AI Act, Article 50(4)"@en ;
                    rdfs:comment "A deployer of an AI System generating or manipulating image, audio, or video deep fakes, subject to transparency obligations."@en ;
                    rdfs:label "Deep Fake AI Deployer"@en .


###  https://w3id.org/airco#DeepFakeGeneration
:DeepFakeGeneration rdf:type owl:Class ;
                    rdfs:subClassOf vair:ContentGeneration ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :appliesToContentType ;
                                      owl:someValuesFrom [ rdf:type owl:Class ;
                                                           owl:unionOf ( :SyntheticAudioContent
                                                                         :SyntheticImageContent
                                                                         :SyntheticVideoContent
                                                                       )
                                                         ]
                                    ] ;
                    rdfs:comment "Purpose of generating or manipulating image, audio, or video content constituting a deep fake."@en ;
                    rdfs:label "Deep Fake Generation"@en .


###  https://w3id.org/airco#DisabilityVulnerability
:DisabilityVulnerability rdf:type owl:Class ;
                         rdfs:subClassOf airo:Vulnerability ;
                         rdfs:label "Disability Vulnerability"@en .


###  https://w3id.org/airco#DisclosureRequirement
:DisclosureRequirement rdf:type owl:Class ;
                       rdfs:subClassOf :TransparencyObligation ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasRiskCategory ;
                                         owl:someValuesFrom :TransparencyRiskCategory
                                       ] ;
                       rdfs:comment "A requirement to disclose AI involvement to affected persons."@en ;
                       rdfs:label "Disclosure Requirement"@en .


###  https://w3id.org/airco#DownstreamProvider
:DownstreamProvider rdf:type owl:Class ;
                    rdfs:subClassOf airo:AIProvider ;
                    terms:source "EU AI Act, Article 3(68)"@en ;
                    rdfs:comment "A provider of an AI system, including a general-purpose AI system, which integrates an AI model, regardless of whether the AI model is provided by themselves and vertically integrated or provided by another entity based on contractual relations."@en ;
                    rdfs:label "Downstream Provider"@en .


###  https://w3id.org/airco#DownstreamProviderDocumentation
:DownstreamProviderDocumentation rdf:type owl:Class ;
                                 rdfs:subClassOf airo:Documentation ;
                                 rdfs:comment "Information and documentation supplied to downstream providers to understand capabilities and limitations."@en ;
                                 rdfs:label "Downstream Provider Documentation"@en .


###  https://w3id.org/airco#EUDatabase
:EUDatabase rdf:type owl:Class ;
            rdfs:subClassOf :RegulatoryDatabase ;
            rdfs:comment "The EU database in which high-risk AI systems and real-time remote biometric identification systems must be registered before deployment."@en ;
            rdfs:label "EU Database"@en .


###  https://w3id.org/airco#EmotionInferenceInEducation
:EmotionInferenceInEducation rdf:type owl:Class ;
                             rdfs:subClassOf vair:DetectingEmotionalState ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :appliesToLocality ;
                                               owl:someValuesFrom vair:EducationalSetting
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :appliesToSubject ;
                                               owl:someValuesFrom vair:Student
                                             ] ;
                             rdfs:comment "Purpose of inferring emotions specifically in educational institution contexts."@en ;
                             rdfs:label "Emotion Inference In Education"@en .


###  https://w3id.org/airco#EmotionInferenceInWorkplace
:EmotionInferenceInWorkplace rdf:type owl:Class ;
                             rdfs:subClassOf vair:DetectingEmotionalState ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :appliesToLocality ;
                                               owl:someValuesFrom vair:Workplace
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :appliesToSubject ;
                                               owl:someValuesFrom vair:Employee
                                             ] ;
                             rdfs:comment "Purpose of inferring emotions specifically in workplace contexts."@en ;
                             rdfs:label "Emotion Inference In Workplace"@en .


###  https://w3id.org/airco#EmotionRecognitionAIDeployer
:EmotionRecognitionAIDeployer rdf:type owl:Class ;
                              rdfs:subClassOf :TransparencyRiskAIDeployer ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :hasObligation ;
                                                owl:someValuesFrom :TransparencyObligation_EmotionRecognitionDisclosure
                                              ] ;
                              terms:source "EU AI Act, Article 50(3)"@en ;
                              rdfs:comment "A deployer of an emotion-recognition system, subject to transparency obligations."@en ;
                              rdfs:label "Emotion Recognition AI Deployer"@en .


###  https://w3id.org/airco#EnvironmentalCrime
:EnvironmentalCrime rdf:type owl:Class ;
                    rdfs:subClassOf :SeriousCrime ;
                    rdfs:label "Environmental Crime"@en .


###  https://w3id.org/airco#Exception
:Exception rdf:type owl:Class ;
           rdfs:comment "An exception to a rule under the AI Act."@en ;
           rdfs:label "Exception"@en .


###  https://w3id.org/airco#Exception_ArtisticFictionalWork
:Exception_ArtisticFictionalWork rdf:type owl:Class ;
                                 rdfs:subClassOf :Exception ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasCondition ;
                                                   owl:someValuesFrom :Condition_NonHamperingDisclosure
                                                 ] ;
                                 terms:source "EU AI Act, Article 50(4)"@en ;
                                 rdfs:comment "For artistic, creative, satirical, fictional, or analogous works, transparency is limited to disclosure that does not hamper the display or enjoyment of the work."@en ;
                                 rdfs:label "Artistic, Fictional, or Satirical Work Exception"@en .


###  https://w3id.org/airco#Exception_AssistiveEditing
:Exception_AssistiveEditing rdf:type owl:Class ;
                            rdfs:subClassOf :Exception ;
                            terms:source "EU AI Act, Article 50(2)"@en ;
                            rdfs:comment "Exception for AI systems that perform an assistive function for standard editing."@en ;
                            rdfs:label "Assistive Editing Exception"@en .


###  https://w3id.org/airco#Exception_AugmentingHumanAssessment
:Exception_AugmentingHumanAssessment rdf:type owl:Class ;
                                     rdfs:subClassOf :Exception ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasCondition ;
                                                       owl:someValuesFrom :Condition_HumanAssessmentAugmentation
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasCondition ;
                                                       owl:someValuesFrom :Condition_ObjectiveVerifiableFacts
                                                     ] ;
                                     terms:source "EU AI Act, Article 5(1)(e)"@en ;
                                     rdfs:comment "Exception when used to augment human assessments based on objective, verifiable facts directly linked to criminal activity."@en ;
                                     rdfs:label "Augmenting Human Assessments Exception"@en .


###  https://w3id.org/airco#Exception_BiometricVerification
:Exception_BiometricVerification rdf:type owl:Class ;
                                 rdfs:subClassOf :Exception ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :appliesToCapability ;
                                                   owl:someValuesFrom vair:BiometricIdentification
                                                 ] ;
                                 terms:source "EU AI Act, Annex III, 1(a)"@en ;
                                 rdfs:comment "Biometric verification that confirms a person is who they claim to be is excluded."@en ;
                                 rdfs:label "Biometric Verification Exclusion"@en .


###  https://w3id.org/airco#Exception_CriminalLawEnforcement
:Exception_CriminalLawEnforcement rdf:type owl:Class ;
                                  rdfs:subClassOf :Exception ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :appliesToDomain ;
                                                    owl:someValuesFrom vair:LawEnforcement
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :appliesToPurpose ;
                                                    owl:someValuesFrom [ rdf:type owl:Class ;
                                                                         owl:unionOf ( vair:DetectingCriminalOffences
                                                                                       vair:InvestigatingCriminalOffences
                                                                                       vair:ProsecutingCriminalOffences
                                                                                     )
                                                                       ]
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasException ;
                                                    owl:someValuesFrom :Exception_PublicCrimeReporting
                                                  ] ;
                                  terms:source "EU AI Act, Article 50(1)"@en ;
                                  rdfs:comment "Exception for AI systems authorised by law for detecting, preventing, investigating, or prosecuting criminal offences, subject to appropriate safeguards."@en ;
                                  rdfs:label "Criminal Law Enforcement Exception"@en .


###  https://w3id.org/airco#Exception_DetectsPatterns
:Exception_DetectsPatterns rdf:type owl:Class ;
                           rdfs:subClassOf :HighRiskException ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :appliesToCapability ;
                                             owl:someValuesFrom :DecisionPatternDetection
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :hasCondition ;
                                             owl:someValuesFrom :Condition_NotReplacingHumanAssessment
                                           ] ;
                           terms:source "EU AI Act, Article 6(3)"@en ;
                           rdfs:comment "The AI system detects decision-making patterns or deviations from prior decision-making patterns and is not meant to replace or influence the previously completed human assessment without proper human review."@en ;
                           rdfs:label "Detects Decision-Making Patterns Exception"@en .


###  https://w3id.org/airco#Exception_FinancialFraudDetection
:Exception_FinancialFraudDetection rdf:type owl:Class ;
                                   rdfs:subClassOf :Exception ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :appliesToPurpose ;
                                                     owl:someValuesFrom :FinancialFraudDetection
                                                   ] ;
                                   terms:source "EU AI Act, Annex III, 5(b)"@en ;
                                   rdfs:comment "Exception when the creditworthiness evaluation is used for detecting financial fraud."@en ;
                                   rdfs:label "Financial Fraud Detection Exception"@en .


###  https://w3id.org/airco#Exception_FreeOpenLicenceGPAI
:Exception_FreeOpenLicenceGPAI rdf:type owl:Class ;
                               rdfs:subClassOf :Exception ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasCondition ;
                                                 owl:someValuesFrom :Condition_NotSystemic
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :appliesToSystem ;
                                                 owl:allValuesFrom :FreeOpenLicenceGPAIModel
                                               ] ;
                               terms:source "EU AI Act, Article 53(2)"@en ;
                               rdfs:comment "Free and open licence GPAI models only need to comply with the Copyright Policy and Training Summary obligations, unless the model is systemic."@en ;
                               rdfs:label "Free Open Licence AI Exception"@en .


###  https://w3id.org/airco#Exception_HumanEditorialReview
:Exception_HumanEditorialReview rdf:type owl:Class ;
                                rdfs:subClassOf :Exception ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :hasCondition ;
                                                  owl:someValuesFrom :Condition_EditorialResponsibility
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :hasCondition ;
                                                  owl:someValuesFrom :Condition_MeaningfulHumanReview
                                                ] ;
                                terms:source "EU AI Act, Article 50(4)"@en ;
                                rdfs:comment "Exception where the AI-generated content has undergone meaningful human editorial review and a natural or legal person holds editorial responsibility for the publication."@en ;
                                rdfs:label "Human Editorial Review Exception"@en .


###  https://w3id.org/airco#Exception_ImprovesHumanResult
:Exception_ImprovesHumanResult rdf:type owl:Class ;
                               rdfs:subClassOf :HighRiskException ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :appliesToCapability ;
                                                 owl:someValuesFrom :HumanResultImprovement
                                               ] ;
                               terms:source "EU AI Act, Article 6(3)"@en ;
                               rdfs:comment "The AI system improves the result of a previously completed human activity."@en ;
                               rdfs:label "Improves Human Result Exception"@en .


###  https://w3id.org/airco#Exception_LabellingFilteringLawfulDatasets
:Exception_LabellingFilteringLawfulDatasets rdf:type owl:Class ;
                                            rdfs:subClassOf :Exception ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :hasCondition ;
                                                              owl:someValuesFrom :Condition_LawfullyAcquiredDataset
                                                            ] ;
                                            terms:source "EU AI Act, Article 5(1)(c)"@en ;
                                            rdfs:comment "Exception for labelling or filtering of lawfully acquired biometric datasets."@en ;
                                            rdfs:label "Labelling or Filtering Lawfully Acquired Datasets Exception"@en .


###  https://w3id.org/airco#Exception_LawEnforcementBiometricCategorisation
:Exception_LawEnforcementBiometricCategorisation rdf:type owl:Class ;
                                                 rdfs:subClassOf :Exception ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :appliesToDomain ;
                                                                   owl:someValuesFrom vair:LawEnforcement
                                                                 ] ;
                                                 terms:source "EU AI Act, Article 5(1)(c)"@en ;
                                                 rdfs:comment "Exception when law enforcement categorises biometric data."@en ;
                                                 rdfs:label "Law Enforcement Biometric Categorisation Exception"@en .


###  https://w3id.org/airco#Exception_MedicalReasons
:Exception_MedicalReasons rdf:type owl:Class ;
                          rdfs:subClassOf :Exception ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :affectsArea ;
                                            owl:someValuesFrom vair:Health
                                          ] ;
                          terms:source "EU AI Act, Article 5(1)(g)"@en ;
                          rdfs:comment "Exception when AI action (e.g. emotion inference) is performed for medical reasons."@en ;
                          rdfs:label "Medical Reasons Exception"@en .


###  https://w3id.org/airco#Exception_NarrowProceduralTask
:Exception_NarrowProceduralTask rdf:type owl:Class ;
                                rdfs:subClassOf :HighRiskException ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :appliesToCapability ;
                                                  owl:someValuesFrom :NarrowProceduralTask
                                                ] ;
                                terms:source "EU AI Act, Article 6(3)"@en ;
                                rdfs:comment "The AI system performs a narrow procedural task."@en ;
                                rdfs:label "Narrow Procedural Task Exception"@en .


###  https://w3id.org/airco#Exception_NoSubstantialAlteration
:Exception_NoSubstantialAlteration rdf:type owl:Class ;
                                   rdfs:subClassOf :Exception ;
                                   terms:source "EU AI Act, Article 50(2)"@en ;
                                   rdfs:comment "Exception for AI systems that do not substantially alter the input data provided by the deployer or the semantics thereof."@en ;
                                   rdfs:label "No Substantial Alteration Exception"@en .


###  https://w3id.org/airco#Exception_PoliticalCampaignTools
:Exception_PoliticalCampaignTools rdf:type owl:Class ;
                                  rdfs:subClassOf :Exception ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :appliesToPurpose ;
                                                    owl:someValuesFrom :PoliticalCampaignOrganisation
                                                  ] ;
                                  terms:source "EU AI Act, Annex III, 8(b)"@en ;
                                  rdfs:comment "Exception for AI outputs that do not directly interact with people, like tools used to organise, optimise, and structure political campaigns."@en ;
                                  rdfs:label "Political Campaign Tool Exception"@en .


###  https://w3id.org/airco#Exception_PreparatoryTask
:Exception_PreparatoryTask rdf:type owl:Class ;
                           rdfs:subClassOf :HighRiskException ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :appliesToCapability ;
                                             owl:someValuesFrom :PreparatoryTask
                                           ] ;
                           terms:source "EU AI Act, Article 6(3)"@en ;
                           rdfs:comment "The AI system performs a preparatory task to an assessment relevant for the purpose of the Annex III use cases."@en ;
                           rdfs:label "Preparatory Task Exception"@en .


###  https://w3id.org/airco#Exception_ProfilingOverride
:Exception_ProfilingOverride rdf:type owl:Class ;
                             rdfs:subClassOf :Exception ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :appliesToCapability ;
                                               owl:someValuesFrom vair:Profiling
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :isExceptionTo ;
                                               owl:someValuesFrom :HighRiskException
                                             ] ;
                             terms:source "EU AI Act, Article 6(3)"@en ;
                             rdfs:comment "AI systems listed under Annex III are always considered high risk if they profile individuals, i.e. automated processing of personal data to assess various aspects of a person's life."@en ;
                             rdfs:label "Profiling Always High-Risk Exception"@en .


###  https://w3id.org/airco#Exception_PublicCrimeReporting
:Exception_PublicCrimeReporting rdf:type owl:Class ;
                                rdfs:subClassOf :Exception ;
                                terms:source "EU AI Act, Article 50(1)"@en ;
                                rdfs:comment "Exception for when systems are available for the public to report a criminal offence."@en ;
                                rdfs:label "Public Crime Reporting Exception"@en .


###  https://w3id.org/airco#Exception_RemoteBiometricIdentification_ImminentThreat
:Exception_RemoteBiometricIdentification_ImminentThreat rdf:type owl:Class ;
                                                        rdfs:subClassOf :Exception ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_ObtainAuthorisation
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_RegisterInEUDatabase
                                                                        ] ;
                                                        terms:source "EU AI Act, Article 5(1)(h)(ii)"@en ;
                                                        rdfs:comment "Exception for preventing substantial and imminent threat to life, or foreseeable terrorist attack."@en ;
                                                        rdfs:label "Preventing Imminent Threat to Life or Terrorist Attack RBI Exception"@en .


###  https://w3id.org/airco#Exception_RemoteBiometricIdentification_MissingPersons
:Exception_RemoteBiometricIdentification_MissingPersons rdf:type owl:Class ;
                                                        rdfs:subClassOf :Exception ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :appliesToSubject ;
                                                                          owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                               owl:unionOf ( :AbductionVictim
                                                                                                             :MissingPerson
                                                                                                             :SexualExploitationVictim
                                                                                                             :TraffickingVictim
                                                                                                           )
                                                                                             ]
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_ObtainAuthorisation
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :hasCondition ;
                                                                          owl:someValuesFrom :Condition_RemoteBiometricIdentification_RegisterInEUDatabase
                                                                        ] ;
                                                        terms:source "EU AI Act, Article 5(1)(h)(i)"@en ;
                                                        rdfs:comment "Exception for searching for missing persons, abduction victims, and people who have been human trafficked or sexually exploited."@en ;
                                                        rdfs:label "Searching Missing Persons RBI Exception"@en .


###  https://w3id.org/airco#Exception_RemoteBiometricIdentification_SeriousCrimeSuspects
:Exception_RemoteBiometricIdentification_SeriousCrimeSuspects rdf:type owl:Class ;
                                                              rdfs:subClassOf :Exception ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :appliesToSubject ;
                                                                                owl:someValuesFrom :Suspect
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasCondition ;
                                                                                owl:someValuesFrom :Condition_RemoteBiometricIdentification_AccountForRightsAndFreedoms
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasCondition ;
                                                                                owl:someValuesFrom :Condition_RemoteBiometricIdentification_ConsiderableHarmWithoutTool
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasCondition ;
                                                                                owl:someValuesFrom :Condition_RemoteBiometricIdentification_FundamentalRightsImpactAssessment
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasCondition ;
                                                                                owl:someValuesFrom :Condition_RemoteBiometricIdentification_ObtainAuthorisation
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasCondition ;
                                                                                owl:someValuesFrom :Condition_RemoteBiometricIdentification_RegisterInEUDatabase
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :includesCrimeType ;
                                                                                owl:someValuesFrom :SeriousCrime
                                                                              ] ;
                                                              terms:source "EU AI Act, Article 5(1)(h)(iii)"@en ;
                                                              rdfs:comment "Exception for identifying suspects in serious crimes."@en ;
                                                              rdfs:label "Identifying Suspects in Serious Crimes RBI Exception"@en .


###  https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyAuthorisation
:Exception_RemoteBiometricIdentification_UrgencyAuthorisation rdf:type owl:Class ;
                                                              rdfs:subClassOf :Exception ;
                                                              terms:source "EU AI Act, Article 5(4)"@en ;
                                                              rdfs:comment "In duly justified cases of urgency, deployment of remote biometric identification can commence without authorisation, provided that authorisation is requested within 24 hours. If rejected, deployment must cease immediately, deleting all data, results, and outputs."@en ;
                                                              rdfs:label "Urgency Authorisation RBI Exception"@en .


###  https://w3id.org/airco#Exception_RemoteBiometricIdentification_UrgencyRegistration
:Exception_RemoteBiometricIdentification_UrgencyRegistration rdf:type owl:Class ;
                                                             rdfs:subClassOf :Exception ;
                                                             terms:source "EU AI Act, Article 5(3)"@en ;
                                                             rdfs:comment "In duly justified cases of urgency, deployment of remote biometric identification can commence without registration, provided that it is registered later without undue delay."@en ;
                                                             rdfs:label "Urgency Registration RBI Exception"@en .


###  https://w3id.org/airco#Exception_SafetyReasons
:Exception_SafetyReasons rdf:type owl:Class ;
                         rdfs:subClassOf :Exception ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :affectsArea ;
                                           owl:someValuesFrom vair:Safety
                                         ] ;
                         terms:source "EU AI Act, Article 5(1)(g)"@en ;
                         rdfs:comment "Exception when AI action (e.g. emotion inference) is performed for safety reasons."@en ;
                         rdfs:label "Safety Reasons Exception"@en .


###  https://w3id.org/airco#Exception_TravelDocumentVerification
:Exception_TravelDocumentVerification rdf:type owl:Class ;
                                      rdfs:subClassOf :Exception ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :appliesToPurpose ;
                                                        owl:someValuesFrom vair:VerifyingAuthenticityOfTravelDocument
                                                      ] ;
                                      terms:source "EU AI Act, Annex III, 7(d)"@en ;
                                      rdfs:comment "Exception for verifying travel documents."@en ;
                                      rdfs:label "Travel Document Verification Exclusion"@en .


###  https://w3id.org/airco#FacialImageData
:FacialImageData rdf:type owl:Class ;
                 rdfs:subClassOf :BiometricData ;
                 rdfs:comment "Facial image data."@en ;
                 rdfs:label "Facial Image Data"@en .


###  https://w3id.org/airco#FinancialFraudDetection
:FinancialFraudDetection rdf:type owl:Class ;
                         rdfs:subClassOf vair:Detection ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :appliesToDomain ;
                                           owl:someValuesFrom vair:PrivateService
                                         ] ;
                         rdfs:comment "Detection of financial fraud, which exempts creditworthiness evaluation from high-risk classification."@en ;
                         rdfs:label "Financial Fraud Detection"@en .


###  https://w3id.org/airco#FreeOpenLicence
:FreeOpenLicence rdf:type owl:Class ;
                 rdfs:subClassOf airo:License ;
                 rdfs:comment "A free and open licence under which model parameters, weights, architecture, and usage are publicly available, allowing access, usage, modification, and distribution."@en ;
                 rdfs:label "Free and Open Licence"@en .


###  https://w3id.org/airco#FreeOpenLicenceGPAIModel
:FreeOpenLicenceGPAIModel rdf:type owl:Class ;
                          rdfs:subClassOf airo:GPAIModel ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :hasRiskCategory ;
                                            owl:someValuesFrom :GPAIRiskCategory
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty airo:hasLicense ;
                                            owl:someValuesFrom :FreeOpenLicence
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty airo:hasStakeholder ;
                                            owl:someValuesFrom :GPAIProvider
                                          ] ;
                          terms:source "EU AI Act, Article 53(2)"@en ;
                          rdfs:comment "A GPAI model whose parameters, weights, architecture, and usage are publicly available."@en ;
                          rdfs:label "Free and Open Licence GPAI Model"@en .


###  https://w3id.org/airco#FundamentalRightsImpactAssessment
:FundamentalRightsImpactAssessment rdf:type owl:Class ;
                                   rdfs:subClassOf airo:Documentation ;
                                   rdfs:comment "A fundamental rights impact assessment required before deployment of real-time RemoteBiometricIdentification."@en ;
                                   rdfs:label "Fundamental Rights Impact Assessment"@en .


###  https://w3id.org/airco#GPAIObligation
:GPAIObligation rdf:type owl:Class ;
                rdfs:subClassOf :Obligation ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :appliesToStakeholder ;
                                  owl:someValuesFrom :GPAIProvider
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasRiskCategory ;
                                  owl:someValuesFrom :GPAIRiskCategory
                                ] ;
                terms:source "EU AI Act, Article 53"@en ;
                rdfs:comment "An obligation placed on providers of GPAI models."@en ;
                rdfs:label "GPAI Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_ComplianceDemonstration
:GPAIObligation_ComplianceDemonstration rdf:type owl:Class ;
                                        rdfs:subClassOf :GPAIObligation ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :hasCondition ;
                                                          owl:someValuesFrom :Condition_CodesOfPracticeParticipation
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :hasCondition ;
                                                          owl:someValuesFrom :Condition_CodesOfPracticeScope
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty airo:followsCodeOfConduct ;
                                                          owl:someValuesFrom airo:CodeOfConduct
                                                        ] ;
                                        terms:source "EU AI Act, Article 56"@en ;
                                        rdfs:comment "All GPAI model providers may demonstrate compliance by voluntarily adhering to a code of practice until European harmonised standards are published. Providers that don't adhere must demonstrate alternative adequate means of compliance for Commission approval."@en ;
                                        rdfs:label "GPAI Compliance Demonstration via Codes of Practice Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_CooperateWithHighRisk
:GPAIObligation_CooperateWithHighRisk rdf:type owl:Class ;
                                      rdfs:subClassOf :GPAIObligation ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :appliesToStakeholder ;
                                                        owl:someValuesFrom :HighRiskAIProvider
                                                      ] ;
                                      terms:source "EU AI Act, Article 53(4)"@en ;
                                      rdfs:comment "GPAI system providers should cooperate with high-risk AI system providers to enable the latter's compliance."@en ;
                                      rdfs:label "GPAI Cooperation with High-Risk AI Providers Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_CopyrightPolicy
:GPAIObligation_CopyrightPolicy rdf:type owl:Class ;
                                rdfs:subClassOf :GPAIObligation ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :hasException ;
                                                  owl:someValuesFrom :Exception_FreeOpenLicenceGPAI
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :requiresDocumentation ;
                                                  owl:someValuesFrom :CopyrightPolicy
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty airo:compliesWithRegulation ;
                                                  owl:hasValue :CopyrightDirective
                                                ] ;
                                terms:source "EU AI Act, Article 53(1)(c)"@en ;
                                rdfs:comment "All providers of GPAI models must establish a policy to respect the Copyright Directive."@en ;
                                rdfs:label "GPAI Copyright Policy Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_Cybersecurity
:GPAIObligation_Cybersecurity rdf:type owl:Class ;
                              rdfs:subClassOf :SystemicRiskObligation ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :requiresRiskControl ;
                                                owl:someValuesFrom :CybersecurityProtection
                                              ] ;
                              terms:source "EU AI Act, Article 55(1)(d)"@en ;
                              rdfs:comment "All providers of systemic GPAI models must ensure an adequate level of cybersecurity protection."@en ;
                              rdfs:label "GPAI Cybersecurity Protection Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_DownstreamProviderInfo
:GPAIObligation_DownstreamProviderInfo rdf:type owl:Class ;
                                       rdfs:subClassOf :GPAIObligation ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasException ;
                                                         owl:someValuesFrom :Exception_FreeOpenLicenceGPAI
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :requiresDocumentation ;
                                                         owl:someValuesFrom :DownstreamProviderDocumentation
                                                       ] ;
                                       terms:source "EU AI Act, Article 53(1)(b)"@en ;
                                       rdfs:comment "All providers of GPAI models must draw up information and documentation to supply to downstream providers that intend to integrate the GPAI model into their own AI system, so the latter understands capabilities and limitations and is enabled to comply."@en ;
                                       rdfs:label "GPAI Downstream Provider Information Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_ModelEvaluation
:GPAIObligation_ModelEvaluation rdf:type owl:Class ;
                                rdfs:subClassOf :SystemicRiskObligation ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :requiresRiskControl ;
                                                  owl:someValuesFrom :ModelEvaluation
                                                ] ;
                                terms:source "EU AI Act, Article 55(1)(a)"@en ;
                                rdfs:comment "All providers of systemic GPAI models must perform model evaluations, including conducting and documenting adversarial testing to identify and mitigate systemic risk."@en ;
                                rdfs:label "GPAI Model Evaluation for Systemic Risk Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_SeriousIncidentReporting
:GPAIObligation_SeriousIncidentReporting rdf:type owl:Class ;
                                         rdfs:subClassOf :SystemicRiskObligation ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :appliesToStakeholder ;
                                                           owl:someValuesFrom :AIOffice
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :requiresRiskControl ;
                                                           owl:someValuesFrom :SeriousIncidentReporting
                                                         ] ;
                                         terms:source "EU AI Act, Article 55(1)(c)"@en ;
                                         rdfs:comment "All providers of systemic GPAI models must track, document, and report serious incidents and possible corrective measures to the AI Office and relevant national competent authorities without undue delay."@en ;
                                         rdfs:label "GPAI Serious Incident Reporting Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_SystemicRiskMitigation
:GPAIObligation_SystemicRiskMitigation rdf:type owl:Class ;
                                       rdfs:subClassOf :SystemicRiskObligation ;
                                       terms:source "EU AI Act, Article 55(1)(b)"@en ;
                                       rdfs:comment "All providers of systemic GPAI models must assess and mitigate possible systemic risks, including their sources."@en ;
                                       rdfs:label "GPAI Systemic-Risk Assessment and Mitigation Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_SystemicRiskNotification
:GPAIObligation_SystemicRiskNotification rdf:type owl:Class ;
                                         rdfs:subClassOf :SystemicRiskObligation ;
                                         terms:source "EU AI Act, Article 51(2)"@en ;
                                         rdfs:comment "All providers of systemic GPAI models must notify the Commission if their model meets the systemic risk criterion within 2 weeks."@en ;
                                         rdfs:label "GPAI Systemic-Risk Notification Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_TechnicalDocumentation
:GPAIObligation_TechnicalDocumentation rdf:type owl:Class ;
                                       rdfs:subClassOf :GPAIObligation ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasException ;
                                                         owl:someValuesFrom :Exception_FreeOpenLicenceGPAI
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :requiresDocumentation ;
                                                         owl:someValuesFrom vair:TechnicalDocumentation
                                                       ] ;
                                       terms:source "EU AI Act, Article 53(1)(a)"@en ;
                                       rdfs:comment "All providers of GPAI models must draw up technical documentation, including training and testing process and evaluation results."@en ;
                                       rdfs:label "GPAI Technical Documentation Obligation"@en .


###  https://w3id.org/airco#GPAIObligation_TrainingSummary
:GPAIObligation_TrainingSummary rdf:type owl:Class ;
                                rdfs:subClassOf :GPAIObligation ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :requiresDocumentation ;
                                                  owl:someValuesFrom :TrainingSummary
                                                ] ;
                                terms:source "EU AI Act, Article 53(1)(d)"@en ;
                                rdfs:comment "All providers of GPAI models must publish a sufficiently detailed summary about the content used for training the GPAI model."@en ;
                                rdfs:label "GPAI Training Summary Publication Obligation"@en .


###  https://w3id.org/airco#GPAIProvider
:GPAIProvider rdf:type owl:Class ;
              rdfs:subClassOf airo:AIProvider ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasObligation ;
                                owl:someValuesFrom :GPAIObligation_ComplianceDemonstration
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasObligation ;
                                owl:someValuesFrom :GPAIObligation_CooperateWithHighRisk
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasObligation ;
                                owl:someValuesFrom :GPAIObligation_CopyrightPolicy
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasObligation ;
                                owl:someValuesFrom :GPAIObligation_DownstreamProviderInfo
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasObligation ;
                                owl:someValuesFrom :GPAIObligation_TechnicalDocumentation
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasObligation ;
                                owl:someValuesFrom :GPAIObligation_TrainingSummary
                              ] ;
              terms:source "EU AI Act, Article 53(1)" ;
              rdfs:comment """A provider of a GPAI model subject to all standard GPAI obligations: technical documentation, information and documentation to supply to downstream
providers, respect the Copyright Directive, sufficiently detailed summary about the content used for training ."""@en ;
              rdfs:label "GPAI Provider"@en .


###  https://w3id.org/airco#GPAIRiskCategory
:GPAIRiskCategory rdf:type owl:Class ;
                  rdfs:subClassOf :RiskCategory ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :triggeredByRegulation ;
                                    owl:someValuesFrom airo:GPAIModel
                                  ] ;
                  terms:source "EU AI Act, Chapter V, Articles 51-56"@en ;
                  rdfs:comment "The General Purpose AI Risk category in the AI Act relating to obligations and risks in GPAI systems."@en ;
                  rdfs:label "GPAI Risk Category"@en .


###  https://w3id.org/airco#GPAISystemicRisk
:GPAISystemicRisk rdf:type owl:Class ;
                  rdfs:subClassOf vair:SystemRiskSource ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty airo:isRiskSourceFor ;
                                    owl:someValuesFrom :SystemicRiskGPAIModel
                                  ] ;
                  terms:source "EU AI Act, Article 51(1)"@en ;
                  rdfs:comment "A systemic risk posed by a GPAI model."@en ;
                  rdfs:label "Systemic Risk"@en .


###  https://w3id.org/airco#GeneratingTextContent
:GeneratingTextContent rdf:type owl:Class ;
                       rdfs:subClassOf vair:ContentGeneration ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :appliesToContentType ;
                                         owl:someValuesFrom :SyntheticTextContent
                                       ] ;
                       rdfs:comment "Purpose of generating synthetic text content."@en ;
                       rdfs:label "Generating Text Content"@en .


###  https://w3id.org/airco#HighComputeTraining
:HighComputeTraining rdf:type owl:Class ;
                     rdfs:subClassOf :GPAISystemicRisk ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :hasComputeThreshold ;
                                       owl:hasValue "10^25 FLOPs"
                                     ] ;
                     terms:source "EU AI Act, Article 51(2)"@en ;
                     rdfs:comment "Indicates that the GPAI model was trained using compute exceeding the systemic-risk threshold (10^25 FLOPs)."@en ;
                     rdfs:label "High-Compute Training"@en .


###  https://w3id.org/airco#HighImpactCapability
:HighImpactCapability rdf:type owl:Class ;
                      rdfs:subClassOf :GPAISystemicRisk ;
                      terms:source "EU AI Act, Article 51(1)(a)"@en ;
                      rdfs:comment "Indicates that a GPAI model has high impact capabilities evaluated on the basis of appropriate technical tools and methodologies, including indicators and benchmarks."@en ;
                      rdfs:label "High-Impact Capability"@en .


###  https://w3id.org/airco#HighRiskAIProvider
:HighRiskAIProvider rdf:type owl:Class ;
                    rdfs:subClassOf airo:AIProvider ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_AccuracyRobustnessCybersecurity
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_DataGovernance
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_DocumentNonHighRiskAssessment
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_HumanOversight
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_InstructionsForUse
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_QualityManagementSystem
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_RecordKeeping
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_RiskManagementSystem
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasObligation ;
                                      owl:someValuesFrom :HighRiskObligation_TechnicalDocumentation
                                    ] ;
                    rdfs:comment "A provider of a high-risk AI system, subject to obligations regarding high-risk systems."@en ;
                    rdfs:label "High-Risk AI Provider"@en .


###  https://w3id.org/airco#HighRiskCategory
:HighRiskCategory rdf:type owl:Class ;
                  rdfs:subClassOf :RiskCategory ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :triggeredByRegulation ;
                                    owl:someValuesFrom :HighRiskUseCase
                                  ] ;
                  terms:source "EU AI Act, Chapter III, Articles 6-27, Annex III"@en ;
                  rdfs:comment "The High-Risk category in the AI Act relating to high-risk AI systems."@en ;
                  rdfs:label "High-Risk Category"@en .


###  https://w3id.org/airco#HighRiskException
:HighRiskException rdf:type owl:Class ;
                   rdfs:subClassOf :Exception ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasException ;
                                     owl:someValuesFrom :Exception_ProfilingOverride
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :isExceptionTo ;
                                     owl:someValuesFrom :HighRiskUseCaseAnnexIII
                                   ] ;
                   terms:source "EU AI Act, Article 6(3)"@en ;
                   rdfs:comment "A criterion that may exempt an AI system from high-risk classification under Annex III. These exceptions are overridden when profiling is involved."@en ;
                   rdfs:label "High-Risk Exception Criterion"@en .


###  https://w3id.org/airco#HighRiskObligation
:HighRiskObligation rdf:type owl:Class ;
                    rdfs:subClassOf :Obligation ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :appliesToStakeholder ;
                                      owl:someValuesFrom :HighRiskAIProvider
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasRiskCategory ;
                                      owl:someValuesFrom :HighRiskCategory
                                    ] ;
                    terms:source "EU AI Act, Articles 6, 8-17"@en ;
                    rdfs:comment "An obligation placed on providers of high-risk AI systems."@en ;
                    rdfs:label "High-Risk Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_AccuracyRobustnessCybersecurity
:HighRiskObligation_AccuracyRobustnessCybersecurity rdf:type owl:Class ;
                                                    rdfs:subClassOf :HighRiskObligation ;
                                                    terms:source "EU AI Act, Article 15"@en ;
                                                    rdfs:comment "High-risk AI providers must design their high-risk AI system to achieve appropriate levels of accuracy, robustness, and cybersecurity."@en ;
                                                    rdfs:label "Accuracy, Robustness, and Cybersecurity Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_DataGovernance
:HighRiskObligation_DataGovernance rdf:type owl:Class ;
                                   rdfs:subClassOf :HighRiskObligation ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :requiresRiskControl ;
                                                     owl:someValuesFrom :DataGovernance
                                                   ] ;
                                   terms:source "EU AI Act, Article 10"@en ;
                                   rdfs:comment "High-risk AI providers must conduct data governance ensuring that training, validation, and testing datasets are relevant, sufficiently representative, and to the best extent possible, free of errors and complete according to the intended purpose."@en ;
                                   rdfs:label "Data Governance Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_DocumentNonHighRiskAssessment
:HighRiskObligation_DocumentNonHighRiskAssessment rdf:type owl:Class ;
                                                  rdfs:subClassOf :HighRiskObligation ;
                                                  terms:source "EU AI Act, Article 6(4)"@en ;
                                                  rdfs:comment "Providers whose AI system falls under Annex III use cases but believes it is not high risk must document such an assessment before placing it on the market or putting it into service."@en ;
                                                  rdfs:label "Document Non-High-Risk Assessment Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_HumanOversight
:HighRiskObligation_HumanOversight rdf:type owl:Class ;
                                   rdfs:subClassOf :HighRiskObligation ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :requiresRiskControl ;
                                                     owl:someValuesFrom vair:HumanOversightMeasure
                                                   ] ;
                                   terms:source "EU AI Act, Article 14"@en ;
                                   rdfs:comment "High-risk AI providers must design their high-risk AI system to allow deployers to implement human oversight."@en ;
                                   rdfs:label "Human Oversight Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_InstructionsForUse
:HighRiskObligation_InstructionsForUse rdf:type owl:Class ;
                                       rdfs:subClassOf :HighRiskObligation ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :requiresDocumentation ;
                                                         owl:someValuesFrom vair:InstructionForUse
                                                       ] ;
                                       terms:source "EU AI Act, Article 13"@en ;
                                       rdfs:comment "High-risk AI providers must provide instructions for use to downstream deployers to enable the latter's compliance."@en ;
                                       rdfs:label "Instructions for Use Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_QualityManagementSystem
:HighRiskObligation_QualityManagementSystem rdf:type owl:Class ;
                                            rdfs:subClassOf :HighRiskObligation ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :requiresRiskControl ;
                                                              owl:someValuesFrom :QualityManagementSystem
                                                            ] ;
                                            terms:source "EU AI Act, Article 17"@en ;
                                            rdfs:comment "High-risk AI providers must establish a quality management system to ensure compliance."@en ;
                                            rdfs:label "Quality Management System Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_RecordKeeping
:HighRiskObligation_RecordKeeping rdf:type owl:Class ;
                                  rdfs:subClassOf :HighRiskObligation ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :requiresRiskControl ;
                                                    owl:someValuesFrom :RecordKeepingCapability
                                                  ] ;
                                  terms:source "EU AI Act, Article 12"@en ;
                                  rdfs:comment "High-risk AI providers must design their high-risk AI system for record-keeping to enable automatic recording of events relevant for identifying national-level risks and substantial modifications throughout the system's lifecycle."@en ;
                                  rdfs:label "Record-Keeping Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_RiskManagementSystem
:HighRiskObligation_RiskManagementSystem rdf:type owl:Class ;
                                         rdfs:subClassOf :HighRiskObligation ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :requiresRiskControl ;
                                                           owl:someValuesFrom :RiskManagementSystem
                                                         ] ;
                                         terms:source "EU AI Act, Article 9"@en ;
                                         rdfs:comment "High-risk AI providers must establish a risk management system throughout the high-risk AI system's lifecycle."@en ;
                                         rdfs:label "Risk Management System Obligation"@en .


###  https://w3id.org/airco#HighRiskObligation_TechnicalDocumentation
:HighRiskObligation_TechnicalDocumentation rdf:type owl:Class ;
                                           rdfs:subClassOf :HighRiskObligation ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :requiresDocumentation ;
                                                             owl:someValuesFrom vair:TechnicalDocumentation
                                                           ] ;
                                           terms:source "EU AI Act, Article 11"@en ;
                                           rdfs:comment "High-risk AI providers must draw up technical documentation to demonstrate compliance and provide authorities with the information to assess that compliance."@en ;
                                           rdfs:label "Technical Documentation Obligation"@en .


###  https://w3id.org/airco#HighRiskUseCase
:HighRiskUseCase rdf:type owl:Class ;
                 rdfs:subClassOf :UseCase ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :appliesToStakeholder ;
                                   owl:someValuesFrom :HighRiskAIProvider
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasRiskCategory ;
                                   owl:someValuesFrom :HighRiskCategory
                                 ] ;
                 rdfs:comment "High-Risk AI practice."@en ;
                 rdfs:label "High-Risk Use Case"@en .


###  https://w3id.org/airco#HighRiskUseCaseAnnexIII
:HighRiskUseCaseAnnexIII rdf:type owl:Class ;
                         rdfs:subClassOf :HighRiskUseCase ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :hasException ;
                                           owl:someValuesFrom [ rdf:type owl:Class ;
                                                                owl:unionOf ( :Exception_DetectsPatterns
                                                                              :Exception_ImprovesHumanResult
                                                                              :Exception_NarrowProceduralTask
                                                                              :Exception_PreparatoryTask
                                                                            )
                                                              ]
                                         ] ;
                         terms:source "EU AI Act, Article 6(2), Annex III"@en ;
                         rdfs:comment "AI systems listed under Annex III use cases are high risk, subject to exceptions."@en ;
                         rdfs:label "High-Risk Use Case under Annex III Legislation"@en .


###  https://w3id.org/airco#HighRiskUseCase_AssessingEducationLevel
:HighRiskUseCase_AssessingEducationLevel rdf:type owl:Class ;
                                         rdfs:subClassOf :HighRiskUseCaseAnnexIII ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :appliesToDomain ;
                                                           owl:someValuesFrom vair:Education
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
