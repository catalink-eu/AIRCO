                                     owl:someValuesFrom :ProhibitedCategory
                                   ] ;
                   rdfs:comment "Prohibited AI practice."@en ;
                   rdfs:label "Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_BiometricCategorisationProhibitedSensitive
:ProhibitedUseCase_BiometricCategorisationProhibitedSensitive rdf:type owl:Class ;
                                                              rdfs:subClassOf :ProhibitedUseCase ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :appliesToCapability ;
                                                                                owl:someValuesFrom vair:BiometricCategorisation
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :appliesToCapability ;
                                                                                owl:someValuesFrom vair:SensitiveAttributeInference
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :appliesToInput ;
                                                                                owl:someValuesFrom :BiometricData
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasException ;
                                                                                owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                     owl:unionOf ( :Exception_LabellingFilteringLawfulDatasets
                                                                                                                   :Exception_LawEnforcementBiometricCategorisation
                                                                                                                 )
                                                                                                   ]
                                                                              ] ,
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :infersSensitiveAttribute ;
                                                                                owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                     owl:unionOf ( :PhilosophicalBeliefs
                                                                                                                   :PoliticalOpinions
                                                                                                                   :Race
                                                                                                                   :ReligiousBeliefs
                                                                                                                   :SexLife
                                                                                                                   :SexualOrientation
                                                                                                                   :TradeUnionMembership
                                                                                                                 )
                                                                                                   ]
                                                                              ] ;
                                                              terms:source "EU AI Act, Article 5(1)(g)"@en ;
                                                              rdfs:comment "Prohibition on biometric categorisation systems inferring the race, political opinions, trade union membership, religious or philosophical beliefs, sex life, or sexual orientation of a natural person."@en ;
                                                              rdfs:label "Biometric Categorisation Inferring Prohibited Sensitive Attributes Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_CriminalRiskProfiling
:ProhibitedUseCase_CriminalRiskProfiling rdf:type owl:Class ;
                                         rdfs:subClassOf :ProhibitedUseCase ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :appliesToCapability ;
                                                           owl:someValuesFrom vair:Profiling
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :appliesToInput ;
                                                           owl:someValuesFrom :PersonalTraitData
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :appliesToPurpose ;
                                                           owl:someValuesFrom vair:PredictingRiskOfOffending
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasCondition ;
                                                           owl:someValuesFrom :Condition_SolelyBasedOnProfiling
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasException ;
                                                           owl:someValuesFrom :Exception_AugmentingHumanAssessment
                                                         ] ;
                                         terms:source "EU AI Act, Article 5(1)(d)"@en ;
                                         rdfs:comment "Prohibition on assessing the risk of an individual committing criminal offenses solely based on profiling or personality traits."@en ;
                                         rdfs:label "Criminal Risk Assessment Solely Based on Profiling Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_EmotionInferenceWorkplaceEducation
:ProhibitedUseCase_EmotionInferenceWorkplaceEducation rdf:type owl:Class ;
                                                      rdfs:subClassOf :ProhibitedUseCase ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :appliesToCapability ;
                                                                        owl:someValuesFrom vair:EmotionRecognition
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :appliesToPurpose ;
                                                                        owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( :EmotionInferenceInEducation
                                                                                                           :EmotionInferenceInWorkplace
                                                                                                         )
                                                                                           ]
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :hasException ;
                                                                        owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( :Exception_MedicalReasons
                                                                                                           :Exception_SafetyReasons
                                                                                                         )
                                                                                           ]
                                                                      ] ;
                                                      terms:source "EU AI Act, Article 5(1)(f)"@en ;
                                                      rdfs:comment "Prohibition on inferring emotions in workplaces or educational institutions, except for medical or safety reasons."@en ;
                                                      rdfs:label "Inferring Emotions in Workplaces and Educational Institutions Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_ExploitingVulnerabilities
:ProhibitedUseCase_ExploitingVulnerabilities rdf:type owl:Class ;
                                             rdfs:subClassOf :ProhibitedUseCase ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :appliesToSubject ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( vair:VulnerableGroup
                                                                                                  vair:VulnerablePerson
                                                                                                )
                                                                                  ]
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :causesConsequence ;
                                                               owl:someValuesFrom vair:ExploitationOfVulnerability
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :causesConsequence ;
                                                               owl:someValuesFrom vair:MaterialDistortionOfBehaviour
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :causesImpact ;
                                                               owl:someValuesFrom vair:Harm
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :exploitsVulnerabilityType ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( :AgeVulnerability
                                                                                                  :DisabilityVulnerability
                                                                                                  :SocioEconomicVulnerability
                                                                                                )
                                                                                  ]
                                                             ] ;
                                             terms:source "EU AI Act, Article 5(1)(b)"@en ;
                                             rdfs:comment "Prohibition on AI systems exploiting vulnerabilities related to age, disability, or socio-economic circumstances to distort behaviour, causing significant harm."@en ;
                                             rdfs:label "Exploiting Vulnerabilities Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_FacialRecognitionDatabaseScraping
:ProhibitedUseCase_FacialRecognitionDatabaseScraping rdf:type owl:Class ;
                                                     rdfs:subClassOf :ProhibitedUseCase ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :appliesToCapability ;
                                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( vair:FaceRecognition
                                                                                                          vair:WebScraping
                                                                                                        )
                                                                                          ]
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :appliesToInput ;
                                                                       owl:someValuesFrom :FacialImageData
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :appliesToPurpose ;
                                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( vair:CreatingFacialRecognitionDatabase
                                                                                                          vair:ExpandingFacialRecognitionDatabase
                                                                                                        )
                                                                                          ]
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :hasDataSource ;
                                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( :CCTVFootage
                                                                                                          :ScrapedFacialImages
                                                                                                        )
                                                                                          ]
                                                                     ] ;
                                                     terms:source "EU AI Act, Article 5(1)(e)"@en ;
                                                     rdfs:comment "Prohibition on compiling facial recognition databases by untargeted scraping of facial images from the internet or CCTV footage."@en ;
                                                     rdfs:label "Compiling Facial Recognition Databases by Untargeted Scraping Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_RealTimeRemoteBiometricIdentification
:ProhibitedUseCase_RealTimeRemoteBiometricIdentification rdf:type owl:Class ;
                                                         rdfs:subClassOf :ProhibitedUseCase ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty :appliesToCapability ;
                                                                           owl:someValuesFrom vair:RealTimeRemoteBiometricIdentification
                                                                         ] ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty :appliesToDomain ;
                                                                           owl:someValuesFrom vair:LawEnforcement
                                                                         ] ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty :appliesToLocality ;
                                                                           owl:someValuesFrom vair:PubliclyAccessibleSpace
                                                                         ] ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty :appliesToStakeholder ;
                                                                           owl:someValuesFrom vair:LawEnforcementAuthority
                                                                         ] ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty :hasException ;
                                                                           owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                owl:unionOf ( :Exception_RemoteBiometricIdentification_ImminentThreat
                                                                                                              :Exception_RemoteBiometricIdentification_MissingPersons
                                                                                                              :Exception_RemoteBiometricIdentification_SeriousCrimeSuspects
                                                                                                            )
                                                                                              ]
                                                                         ] ;
                                                         terms:source "EU AI Act, Article 5(1)(h)"@en ;
                                                         rdfs:comment "Prohibition on real-time remote biometric identification in publicly accessible spaces for law enforcement."@en ;
                                                         rdfs:label "Real-Time Remote Biometric Identification in Public Spaces Prohibited Use Case"@en .


###  https://w3id.org/airco#ProhibitedUseCase_SocialScoring
:ProhibitedUseCase_SocialScoring rdf:type owl:Class ;
                                 rdfs:subClassOf :ProhibitedUseCase ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :appliesToCapability ;
                                                   owl:someValuesFrom vair:SocialScoring
                                                 ] ,
                                                 [ rdf:type owl:Restriction ;
